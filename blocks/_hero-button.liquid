<a {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %} class="btn btn-primary" {{ block.shopify_attributes }}>
  {{ block.settings.label | default: "Shop Now" }}
</a>

{% schema %}
{
  "name": "Hero Button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Button"
    }
  ]
}
{% endschema %}
