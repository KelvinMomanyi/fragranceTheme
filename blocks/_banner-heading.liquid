{% if block.settings.heading != blank %}
  <h2 class="h2 card-title" {{ block.shopify_attributes }}>{{ block.settings.heading }}</h2>
{% endif %}

{% schema %}
{
  "name": "Banner heading",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Our Latest Velour Collection"
    }
  ],
  "presets": [
    {
      "name": "Banner heading"
    }
  ]
}
{% endschema %}
