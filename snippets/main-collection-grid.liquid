{% comment %}
  Renders the main collection grid
  Accepts:
  - current_collection: {Object} The collection object to render
  - section: {Object} The section object
  - paginate: {Object} The paginate object
{% endcomment %}

{%- liquid
  assign products_per_row = section.settings.products_per_row | default: 4 | plus: 0
  assign grid_density_options = '3,4,5,6' | split: ','

  if products_per_row < 3
    assign products_per_row = 3
  elsif products_per_row > 6
    assign products_per_row = 6
  endif
-%}

<div class="{% if section.settings.filter_type == 'vertical' %}facets-vertical{% endif %}">
  {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
    <aside
      aria-labelledby="verticalTitle"
      class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}"
      id="main-collection-filters"
      data-id="{{ section.id }}"
    >
      {% render 'facets',
        results: current_collection,
        enable_filtering: section.settings.enable_filtering,
        enable_sorting: section.settings.enable_sorting,
        filter_type: section.settings.filter_type,
        paginate: paginate,
        section_id: section.id
      %}
    </aside>
  {%- endif -%}

  <div class="product-grid-container" id="ProductGridContainer">
    {%- if current_collection.products.size == 0 -%}
      <div class="collection collection--empty" id="product-grid" data-id="{{ section.id }}">
        <div class="loading-overlay gradient"></div>
        <div class="title-wrapper center">
          <h2 class="title title--primary">
            {{ 'sections.collection_template.empty' | t -}}
            <br>
            {{
              'sections.collection_template.use_fewer_filters_html'
              | t: link: current_collection.url, class: 'underlined-link link'
            }}
          </h2>
        </div>
      </div>
    {%- else -%}
      <div class="collection">
        <div class="loading-overlay gradient"></div>
        
        <!-- Strategic product count + grid density controls -->
        <div class="collection-grid-topbar">
          <div class="product-count strategic-product-count" role="status">
            <h2 class="product-count__text text-body">
              <span>
                {%- if current_collection.results_count -%}
                  {{
                    'templates.search.results_with_count'
                    | t: terms: current_collection.terms, count: current_collection.results_count
                  }}
                {%- elsif current_collection.products_count == current_collection.all_products_count -%}
                  {{ 'products.facets.product_count_simple' | t: count: current_collection.products_count }}
                {%- else -%}
                  {{
                    'products.facets.product_count'
                    | t: product_count: current_collection.products_count, count: current_collection.all_products_count
                  }}
                {%- endif -%}
              </span>
            </h2>
          </div>

          <div
            class="collection-grid-controls"
            data-collection-grid-controls
            data-section-id="{{ section.id }}"
            data-default-columns="{{ products_per_row }}"
            data-min-columns="3"
            data-max-columns="6"
          >
            <div class="collection-grid-controls__group" role="group" aria-label="Grid density selector">
              {%- for option in grid_density_options -%}
                {%- assign option_value = option | plus: 0 -%}
                <button
                  type="button"
                  class="collection-grid-controls__option{% if option_value == products_per_row %} is-selected{% endif %}"
                  data-grid-columns-set="{{ option_value }}"
                  aria-label="Show {{ option_value }} products per row"
                  aria-pressed="{% if option_value == products_per_row %}true{% else %}false{% endif %}"
                  title="{{ option_value }} per row"
                >
                  <span class="collection-grid-controls__icon" aria-hidden="true">
                    {%- case option_value -%}
                      {%- when 3 -%}
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" focusable="false">
                          <rect x="2.5" y="4" width="3.6" height="12" rx="1.8" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="8.2" y="4" width="3.6" height="12" rx="1.8" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="13.9" y="4" width="3.6" height="12" rx="1.8" stroke="currentColor" stroke-width="0.7"></rect>
                        </svg>
                      {%- when 4 -%}
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" focusable="false">
                          <rect x="1.6" y="4" width="2.8" height="12" rx="1.4" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="6.1" y="4" width="2.8" height="12" rx="1.4" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="10.6" y="4" width="2.8" height="12" rx="1.4" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="15.1" y="4" width="2.8" height="12" rx="1.4" stroke="currentColor" stroke-width="0.7"></rect>
                        </svg>
                      {%- when 5 -%}
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" focusable="false">
                          <rect x="1.3" y="4" width="2.1" height="12" rx="1.05" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="5.0" y="4" width="2.1" height="12" rx="1.05" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="8.7" y="4" width="2.1" height="12" rx="1.05" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="12.4" y="4" width="2.1" height="12" rx="1.05" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="16.1" y="4" width="2.1" height="12" rx="1.05" stroke="currentColor" stroke-width="0.7"></rect>
                        </svg>
                      {%- when 6 -%}
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" focusable="false">
                          <rect x="1.2" y="4" width="1.7" height="12" rx="0.85" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="4.2" y="4" width="1.7" height="12" rx="0.85" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="7.2" y="4" width="1.7" height="12" rx="0.85" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="10.2" y="4" width="1.7" height="12" rx="0.85" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="13.2" y="4" width="1.7" height="12" rx="0.85" stroke="currentColor" stroke-width="0.7"></rect>
                          <rect x="16.2" y="4" width="1.7" height="12" rx="0.85" stroke="currentColor" stroke-width="0.7"></rect>
                        </svg>
                    {%- endcase -%}
                  </span>
                </button>
              {%- endfor -%}
            </div>
          </div>
        </div>

        <ul
          id="product-grid"
          data-id="{{ section.id }}"
          class="collection-grid collection-grid--adjustable"
          data-collection-grid
          data-section-id="{{ section.id }}"
          data-default-columns="{{ products_per_row }}"
          data-min-columns="3"
          data-max-columns="6"
          style="--products-per-row: {{ products_per_row }}; display: grid; gap: 20px; list-style: none; padding: 0;"
        >
          {%- for product in current_collection.products -%}
            <li class="grid__item decoration">
               <div class="product-card">
                <a
                  href="{{ product.url }}"
                  class="card-banner img-holder has-before"
                  style="--width: 300; --height: 300;"
                >
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                              {{ product.featured_image | image_url: width: 450 }} 450w,
                              {{ product.featured_image | image_url: width: 600 }} 600w"
                      sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 300px"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="img-cover"
                      width="300"
                      height="300"
                      loading="lazy"
                    >
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'img-cover' }}
                  {% endif %}
                  <ul class="card-action-list">
                    <li>
                      <button class="card-action-btn" aria-label="add to cart" title="add to cart">
                        {% render 'icon-velour', icon: 'add' %}
                      </button>
                    </li>
                    <li>
                       <form action="/cart/add" method="post" enctype="multipart/form-data" class="add-to-cart-form">
                          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                          <button type="submit" class="card-action-btn" aria-label="add to cart">
                            {% render 'icon-velour', icon: 'bag-handle' %}
                          </button>
                        </form>
                    </li>
                  </ul>
                  {% if product.compare_at_price > product.price %}
                    <ul class="badge-list">
                      <li>
                        <div class="badge orange">Sale</div>
                      </li>
                      <li>
                        <div class="badge cyan">{%- assign savings = product.compare_at_price | minus: product.price -%}{%- assign savings_percent = savings | times: 100 | divided_by: product.compare_at_price -%}{{ savings_percent }}%</div>
                      </li>
                    </ul>
                  {% endif %}
                </a>
                <div class="card-content">
                  <h3 class="h3">
                    <a href="{{ product.url }}" class="card-title">{{ product.title }}</a>
                  </h3>
                  <div class="card-price">
                    {% if product.compare_at_price > product.price %}
                      <del class="del">{{ product.compare_at_price | money }}</del>
                    {% endif %}
                    {% if product.price_varies %}
                      <span class="price-from">From </span>
                    {% endif %}
                    <data class="price" value="{{ product.price }}">{{ product.price | money }}</data>
                  </div>
                   {% assign first_variant = product.selected_or_first_available_variant %}
                     {% if first_variant.unit_price_measurement %}
                        <div class="unit-price">
                          {{ first_variant.unit_price | money }}/{{ first_variant.unit_price_measurement.reference_value }}{{ first_variant.unit_price_measurement.reference_unit }}
                        </div>
                     {% endif %}
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
           {% render 'pagination', paginate: paginate, anchor: '' %}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>
