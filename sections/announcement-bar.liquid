{% if section.settings.enabled %}
 <header class="color-scheme-{{ section.settings.color_scheme.id | default: section.settings.color_scheme }}" 
         style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}" 
         data-section-id="{{ section.id }}"> 
    <div class="alert" style="background-color: transparent !important; color: inherit !important;">
        <div class="flexBox">
          <div id="phone-container">
            <ul class="social-list" style="gap: 15px;">
              {% if section.settings.show_facebook_icon %}
                <li>
                  <a href="{{ settings.social_facebook }}" class="social-link" target="_blank" rel="noopener" aria-label="Facebook">
                    {% render 'icon-velour', icon: 'facebook', size: 'small' %}
                  </a>
                </li>
              {% endif %}

              {% if section.settings.show_instagram_icon %}
                <li>
                  <a href="{{ settings.social_instagram }}" class="social-link" target="_blank" rel="noopener" aria-label="Instagram">
                    {% render 'icon-velour', icon: 'instagram', size: 'small' %}
                  </a>
                </li>
              {% endif %}

              {% if section.settings.show_tiktok_icon %}
                <li>
                  <a href="{{ settings.social_tiktok }}" class="social-link" target="_blank" rel="noopener" aria-label="TikTok">
                    {% render 'icon-velour', icon: 'tiktok', size: 'small' %}
                  </a>
                </li>
              {% endif %}

              {% if section.settings.show_tumblr_icon %}
                <li>
                  <a href="{{ settings.social_tumblr }}" class="social-link" target="_blank" rel="noopener" aria-label="Tumblr">
                    {% render 'icon-velour', icon: 'tumblr', size: 'small' %}
                  </a>
                </li>
              {% endif %}
            </ul>
          </div>
          <div class="slider-wrapper">
            {% if section.blocks.size > 0 %}
              {% content_for 'blocks' %}
            {% else %}
              <p class="alert-text" id="text1">Free Shipping On All U.S. Orders $50+</p>
              <p class="alert-text" id="text2">Save Up to 40%</p>
              <p class="alert-text" id="text3">Get Your Gear Faster</p>
            {% endif %}
          </div>
          
          <!-- Language and Currency Selectors Container -->
        <div id="language-currency-container">
          {%- form 'localization', id: 'AnnouncementLocalizationForm', class: 'localization-form' -%}
            <select name="language_code" class="locale-selector" onchange="this.form.submit()">
              {% for language in localization.available_languages %}
                <option value="{{ language.iso_code }}" {% if language.iso_code == localization.language.iso_code %}selected{% endif %}>
                  {{ language.endonym_name | capitalize }}
                </option>
              {% endfor %}
            </select>
            
            <div class='separator'></div>

            <div class="currency-custom-container">
              <div class="dropdown" id="currency-dropdown-announcement">
                <div class="select">
                  <span class="selected">
                    <div class="flag-icon" style="background-image: url('{{ localization.country | image_url: width: 32 }}');" aria-label="{{ localization.country.name }} flag"></div>
                    <span>{{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}</span>
                  </span>
                  <div class="caret-icon-wrapper">
                    {% render 'icon-velour', icon: 'chevron-down', size: 'small' %}
                  </div>
                </div>
                <ul class="newmenu">
                  {% for country in localization.available_countries %}
                    <li data-value="{{ country.iso_code }}" {% if country.iso_code == localization.country.iso_code %}class="active"{% endif %}>
                      <div class="flag-icon" style="background-image: url('{{ country | image_url: width: 32 }}');"></div>
                      <span>{{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})</span>
                    </li>
                  {% endfor %}
                </ul>
              </div>
              <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
            </div>
          {%- endform -%}
        </div>
           {% comment %} {% render 'icon-velour', icon: 'close' %} {% endcomment %}
        </div>
      </div>
 </header>

{{ 'section-announcement-bar.css' | asset_url | stylesheet_tag }} 

<script>
(function() {
  var announcementInterval = null;

  function initAnnouncementBar(root) {
    var sectionRoot = root || document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!sectionRoot) return;

    /* Clear any previous interval to avoid duplicates */
    if (announcementInterval) clearInterval(announcementInterval);

    var texts = sectionRoot.querySelectorAll('.slider-wrapper .alert-text');
    if (texts.length === 0) return;

    var currentIndex = 0;

    function slideToMiddle(element) {
      if (!element) return;
      element.classList.add('visible');
    }

    function resetPosition(element) {
      if (!element) return;
      element.classList.remove('visible');
      element.classList.add('exit');
    }

    function slideText() {
      resetPosition(texts[currentIndex]);
      currentIndex = (currentIndex + 1) % texts.length;
      texts[currentIndex].classList.remove('exit');
      slideToMiddle(texts[currentIndex]);
    }

    /* Mark the wrapper so the CSS :first-child fallback is removed,
       then let JS manage .visible classes from here on. */
    var wrapper = sectionRoot.querySelector('.slider-wrapper');
    if (wrapper) wrapper.classList.add('js-ready');

    slideToMiddle(texts[currentIndex]);
    if (texts.length > 1) {
      announcementInterval = setInterval(slideText, 3000);
    }

    /* ------- Currency dropdown ------- */
    var dropdown = sectionRoot.querySelector('#currency-dropdown-announcement');
    if (dropdown) {
      var select = dropdown.querySelector('.select');
      var caretWrapper = dropdown.querySelector('.caret-icon-wrapper');
      var menu = dropdown.querySelector('.newmenu');
      var options = dropdown.querySelectorAll('.newmenu li');
      var form = dropdown.closest('form');
      var hiddenInput = form ? form.querySelector('input[name="country_code"]') : null;

      if (select && menu) {
        select.addEventListener('click', function(e) {
          e.stopPropagation();
          if (caretWrapper) caretWrapper.classList.toggle('caret-rotate');
          menu.classList.toggle('menu-open');
        });

        options.forEach(function(option) {
          option.addEventListener('click', function() {
            var value = option.getAttribute('data-value');
            if (hiddenInput) hiddenInput.value = value;
            if (form) form.submit();
          });
        });

        document.addEventListener('click', function() {
          if (caretWrapper) caretWrapper.classList.remove('caret-rotate');
          menu.classList.remove('menu-open');
        });
      }
    }
  }

  /* Init immediately – no DOMContentLoaded gate – the <script> is after the
     section HTML so the elements already exist in the DOM at this point. */
  initAnnouncementBar();

  /* Re-init when Shopify editor re-renders this section (e.g. color scheme change) */
  document.addEventListener('shopify:section:load', function(event) {
    if (event.detail.sectionId === '{{ section.id }}') {
      initAnnouncementBar(event.target);
    }
  });
})();
</script>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "color_scheme","id": "color_scheme","label": "Color scheme","default": "scheme-4"
    },
    {
     "type": "checkbox",
     "id": "enabled",
     "label": "Enable Announcement Bar",
     "default": true
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "+1 (123) 456-7890"
    },
     {
      "type": "checkbox",
      "id": "show_facebook_icon",
      "label": "Show Facebook Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_instagram_icon",
      "label": "Show Instagram Icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tiktok_icon",
      "label": "Show TikTok icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tumblr_icon",
      "label": "Show Tumblr icon",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "category": "Marketing",
      "blocks": [
        {
          "type": "_announcement",
          "settings": {
            "text": "Free Shipping On All U.S. Orders $50+"
          }
        },
        {
          "type": "_announcement",
          "settings": {
            "text": "Save Up to 40%"
          }
        },
        {
          "type": "_announcement",
          "settings": {
            "text": "Get Your Gear Faster"
          }
        }
      ]
    }
  ]
}
{% endschema %}



