<section class="section about-story color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}">
  <div class="container about-story__grid about-story__grid--{{ section.settings.image_position }}">
    <div class="about-story__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1400 }}"
          srcset="{{ section.settings.image | image_url: width: 375 }} 375w,
                  {{ section.settings.image | image_url: width: 550 }} 550w,
                  {{ section.settings.image | image_url: width: 750 }} 750w,
                  {{ section.settings.image | image_url: width: 1100 }} 1100w,
                  {{ section.settings.image | image_url: width: 1400 }} 1400w"
          sizes="(min-width: 900px) 50vw, (min-width: 768px) 100vw, 100vw"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <div class="about-story__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="about-story__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h2 class="about-story__title">{{ section.settings.heading }}</h2>

      {%- if section.settings.body != blank -%}
        <div class="about-story__text rte">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.settings.established_label != blank or section.settings.established_value != blank -%}
        <div class="about-story__established">
          <span class="about-story__established-label">{{ section.settings.established_label }}</span>
          <span class="about-story__established-value">{{ section.settings.established_value }}</span>
        </div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="about-story__features">
          {%- for block in section.blocks -%}
            <div class="about-story__feature" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .about-story__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(28px, 4vw, 80px);
    align-items: start;
  }

  .about-story__grid--right .about-story__media {
    order: 2;
  }

  .about-story__media img,
  .about-story__media .placeholder-svg {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid currentColor;
  }

  .about-story__eyebrow {
    font-size: var(--fs-6);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0.75;
  }

  .about-story__title {
    font-size: var(--fs-2);
    margin: 0 0 16px;
    font-weight: var(--fw-500);
  }

  .about-story__text {
    font-size: var(--fs-4);
    line-height: 1.8;
  }

  .about-story__established {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 18px;
    padding-top: 10px;
    border-top: 1px solid currentColor;
    text-transform: uppercase;
    font-size: var(--fs-6);
    letter-spacing: 0.16em;
  }

  .about-story__established-value {
    color: var(--color-button) !important;
    font-weight: 600;
  }

  .about-story__features {
    margin-top: 24px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 18px;
  }

  .about-story__feature {
    padding: 18px;
    border: 1px solid currentColor;
    background: var(--color-background);
    transition: transform var(--transition-1);
  }

  .about-story__feature h3 {
    margin: 0 0 8px;
    font-size: var(--fs-4);
    font-weight: var(--fw-500);
  }

  .about-story__feature p {
    margin: 0;
    font-size: 1.4rem;
    opacity: 0.85;
  }

  .about-story__feature:hover {
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .about-story__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "About story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our craft"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The essence of timeless fragrance"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Every bottle is composed to evoke memory and emotion, blending bold notes with refined balance.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "established_label",
      "label": "Established label",
      "default": "Est."
    },
    {
      "type": "text",
      "id": "established_value",
      "label": "Established value",
      "default": "2019"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Small-batch blending"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Each batch is tuned for balance and longevity."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About story",
      "category": "Storytelling",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}




