<!--OFFER-->
<section class="section offer color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}" id="offer" aria-label="offer" data-aos="fade-up">
    <div class="container">
      {% assign offer_image_blocks = section.blocks | where: "type", "offer_image" %}
      {% assign offer_badge_block = section.blocks | where: "type", "offer_badge" | first %}
      {% assign offer_product_block = section.blocks | where: "type", "offer_product" | first %}
      {% assign offer_description_block = section.blocks | where: "type", "offer_description" | first %}
      {% assign offer_price_block = section.blocks | where: "type", "offer_price" | first %}

      <figure class="offer-banner">
        {% assign offer_image_block_1 = offer_image_blocks[0] %}
        {% assign offer_image_block_2 = offer_image_blocks[1] %}

        {% if offer_image_block_1 %}
          {% if offer_image_block_1.settings.image != blank %}
            <img
              src="{{ offer_image_block_1.settings.image | image_url: width: 610 }}"
              srcset="{{ offer_image_block_1.settings.image | image_url: width: 305 }} 305w,
                      {{ offer_image_block_1.settings.image | image_url: width: 610 }} 610w"
              sizes="(max-width: 480px) 100vw, 305px"
              alt="{{ offer_image_block_1.settings.alt_text | escape }}"
              width="305"
              height="405"
              class="w-100"
              loading="lazy"
              {{ offer_image_block_1.shopify_attributes }}>
          {% else %}
            <div class="offer-placeholder" {{ offer_image_block_1.shopify_attributes }}>
              {{ offer_image_block_1.settings.placeholder | default: 'lifestyle-1' | placeholder_svg_tag: 'offer-placeholder-svg' }}
            </div>
          {% endif %}
        {% endif %}

        {% if offer_image_block_2 %}
          {% if offer_image_block_2.settings.image != blank %}
            <img
              src="{{ offer_image_block_2.settings.image | image_url: width: 610 }}"
              srcset="{{ offer_image_block_2.settings.image | image_url: width: 305 }} 305w,
                      {{ offer_image_block_2.settings.image | image_url: width: 610 }} 610w"
              sizes="(max-width: 480px) 100vw, 305px"
              alt="{{ offer_image_block_2.settings.alt_text | escape }}"
              width="305"
              height="405"
              class="w-100"
              loading="lazy"
              {{ offer_image_block_2.shopify_attributes }}>
          {% else %}
            <div class="offer-placeholder" {{ offer_image_block_2.shopify_attributes }}>
              {{ offer_image_block_2.settings.placeholder | default: 'lifestyle-2' | placeholder_svg_tag: 'offer-placeholder-svg' }}
            </div>
          {% endif %}
        {% endif %}
      </figure>

      <div class="offer-content">
        {% if offer_badge_block %}
          <p class="offer-subtitle" {{ offer_badge_block.shopify_attributes }}>
            <span class="span">{{ offer_badge_block.settings.subtitle }}</span>
            <span class="badge" aria-label="{{ offer_badge_block.settings.percent_offer | escape }}">
              {{ offer_badge_block.settings.percent_offer }}
            </span>
          </p>
        {% endif %}

        {% if offer_product_block %}
          <h2 class="h2-large section-title" {{ offer_product_block.shopify_attributes }}>
            {% if offer_product_block.settings.select_product != blank %}
              {{ offer_product_block.settings.select_product.title }}
            {% else %}
              {{ offer_product_block.settings.fallback_title }}
            {% endif %}
          </h2>
        {% endif %}

        {% if offer_description_block %}
          {% if offer_description_block.settings.product_desc != blank %}
            <p {{ offer_description_block.shopify_attributes }}>
              {{ offer_description_block.settings.product_desc }}
            </p>
          {% else %}
            <p class="section-text" {{ offer_description_block.shopify_attributes }}>
              Conceived as an ode to nature, Sauvage is an act of creation inspired by wide-open spaces. Compositions marked by raw freshness, combining power and nobility.
            </p>
          {% endif %}
        {% endif %}

        {% if offer_price_block %}
          <a href="{{ offer_price_block.settings.button_link | default: '#' }}" class="btn btn-primary offer-cta" {{ offer_price_block.shopify_attributes }}>
            {{ offer_price_block.settings.button_label }} {{ offer_price_block.settings.offer_price }}
          </a>
        {% endif %}
      </div>
    </div>
</section>



<style>
  .offer-placeholder {
    width: 100%;
    aspect-ratio: 305 / 405;
    background-color: #d4d4d4;
    display: flex;
    position: relative;
    overflow: hidden;
  }

  .offer-placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  .offer .offer-cta {
    margin-top: 18px;
    display: inline-block;
  }
</style>




{% schema %}
{
  "name": "Offer",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color_scheme","id": "color_scheme","label": "Color scheme","default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "offer_image",
      "name": "Offer image",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "placeholder",
          "label": "Placeholder",
          "default": "lifestyle-1",
          "options": [
            { "value": "lifestyle-1", "label": "Lifestyle 1" },
            { "value": "lifestyle-2", "label": "Lifestyle 2" }
          ]
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "default": "Offer products"
        }
      ]
    },
    {
      "type": "offer_badge",
      "name": "Offer badge",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Special Offer"
        },
        {
          "type": "text",
          "id": "percent_offer",
          "label": "Percentage offer",
          "default": "-20%"
        }
      ]
    },
    {
      "type": "offer_product",
      "name": "Product title",
      "limit": 1,
      "settings": [
        {
          "type": "product",
          "id": "select_product",
          "label": "Select product"
        },
        {
          "type": "text",
          "id": "fallback_title",
          "label": "Fallback title",
          "default": "Dior Sauvage"
        }
      ]
    },
    {
      "type": "offer_description",
      "name": "Product description",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "product_desc",
          "label": "Description",
          "default": "Conceived as an ode to nature, Sauvage is an act of creation inspired by wide-open spaces. Compositions marked by raw freshness, combining power and nobility."
        }
      ]
    },
    {
      "type": "offer_price",
      "name": "Price button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Get Only"
        },
        {
          "type": "text",
          "id": "offer_price",
          "label": "Offer price",
          "default": "$39"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Offer",
      "category": "Marketing",
      "blocks": [
        {
          "type": "offer_image",
          "settings": {
            "placeholder": "lifestyle-1",
            "alt_text": "Offer products"
          }
        },
        {
          "type": "offer_image",
          "settings": {
            "placeholder": "lifestyle-2",
            "alt_text": "Offer products"
          }
        },
        {
          "type": "offer_badge"
        },
        {
          "type": "offer_product"
        },
        {
          "type": "offer_description"
        },
        {
          "type": "offer_price"
        }
      ]
    }
  ]
}
{% endschema %}




