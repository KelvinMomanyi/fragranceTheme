{%- liquid
  assign overlay_opacity = section.settings.overlay_opacity | times: 0.01
  assign has_buttons = false
  for block in section.blocks
    if block.type == 'button'
      assign has_buttons = true
    endif
  endfor
-%}

<section class="section about-cta color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}">
  <div class="about-cta__media" style="--about-cta-overlay: {{ overlay_opacity }};">
    {%- if section.settings.background_image != blank -%}
      <img
        src="{{ section.settings.background_image | image_url: width: 1400 }}"
        srcset="{{ section.settings.background_image | image_url: width: 375 }} 375w,
                {{ section.settings.background_image | image_url: width: 550 }} 550w,
                {{ section.settings.background_image | image_url: width: 750 }} 750w,
                {{ section.settings.background_image | image_url: width: 1100 }} 1100w,
                {{ section.settings.background_image | image_url: width: 1500 }} 1500w,
                {{ section.settings.background_image | image_url: width: 2000 }} 2000w"
        sizes="100vw"
        alt="{{ section.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ section.settings.background_image.width }}"
        height="{{ section.settings.background_image.height }}"
      >
    {%- endif -%}
  </div>

  <div class="container about-cta__content">
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}
      <div class="about-cta__text rte">{{ section.settings.text }}</div>
    {%- endif -%}

    {%- if has_buttons -%}
      <div class="about-cta__actions">
        {%- for block in section.blocks -%}
          {%- if block.type == 'button' -%}
            {%- assign button_class = 'btn btn-primary' -%}
            {%- if block.settings.style == 'secondary' -%}
              {%- assign button_class = 'btn btn-secondary' -%}
            {%- endif -%}
            <a class="{{ button_class }}" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .about-cta {
    position: relative;
    overflow: hidden;
    padding: clamp(60px, 10vw, 120px) 0;
    text-align: center;
    color: var(--color-text);
  }

  .about-cta__media {
    position: absolute;
    inset: 0;
    background: var(--color-background);
  }

  .about-cta__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--about-cta-overlay, 0.35));
  }

  .about-cta__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-cta__content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    display: grid;
    gap: 16px;
  }

  .about-cta__content h2 {
    font-size: var(--fs-2);
    margin: 0;
    font-weight: var(--fw-500);
  }

  .about-cta__text {
    font-size: var(--fs-4);
    opacity: 0.9;
  }

  .about-cta__actions {
    margin-top: 10px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

{% schema %}
{
  "name": "About CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore our signature collection"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Discover the fragrance that feels like your next chapter.</p>"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 35
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "primary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About CTA",
      "category": "Storytelling",
      "blocks": [
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}




