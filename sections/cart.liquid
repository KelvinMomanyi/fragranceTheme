<div class="cart-container">
{% if cart.item_count > 0 %}
  <h1>Shopping Cart</h1>
  <form action="{{ routes.cart_url }}" method="post" novalidate>
    <table class="cart-table">
      <thead>
        <tr>
          <th colspan="2">Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        {% for item in cart.items %}
          <tr class="cart-item" data-line="{{ forloop.index }}">
            <td class="cart-item__image">
              <a href="{{ item.url | within: collections.all }}">
                <img src="{{ item | image_url: width: 240 }}" width="104" height="104" alt="{{ item.title | escape }}" loading="lazy">
              </a>
            </td>
            <td class="cart-item__details">
              <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
              {%- if item.product.has_only_default_variant == false or item.properties.size != 0 -%}
                <dl class="cart-item__options">
                  {%- if item.product.has_only_default_variant == false -%}
                    {%- for option in item.options_with_values -%}
                      <div class="cart-item__option">
                        <dt>{{ option.name }}: </dt>
                        <dd>{{ option.value }}</dd>
                      </div>
                    {%- endfor -%}
                  {%- endif -%}

                  {%- for property in item.properties -%}
                    {%- assign property_first_char = property.first | slice: 0 -%}
                    {%- if property.last != blank and property_first_char != '_' -%}
                      <div class="cart-item__option">
                        <dt>{{ property.first }}: </dt>
                        <dd>
                          {%- if property.last contains '/uploads/' -%}
                            <a href="{{ property.last }}" target="_blank" rel="noopener noreferrer">
                              {{ property.last | split: '/' | last }}
                            </a>
                          {%- else -%}
                            {{ property.last }}
                          {%- endif -%}
                        </dd>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </dl>
              {%- endif -%}
              
              {%- comment -%} Selling Plans Display (Required) {%- endcomment -%}
              {% if item.selling_plan_allocation %}
                <p class="cart-item__selling-plan">
                  <strong>{{ item.selling_plan_allocation.selling_plan.name }}</strong>
                </p>
              {% endif %}
              
              {%- comment -%} Unit Pricing (Required) {%- endcomment -%}
              {% if item.variant.unit_price_measurement %}
                <div class="cart-item__unit-price">
                  <span class="unit-price">
                    {{ item.variant.unit_price | money }}/{{ item.variant.unit_price_measurement.reference_value }}{{ item.variant.unit_price_measurement.reference_unit }}
                  </span>
                </div>
              {% endif %}
              
              <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&amp;quantity=0" class="cart-item__remove">Remove</a>
            </td>
            <td class="cart-item__price">
              {%- comment -%} Show compare-at price if discounted {%- endcomment -%}
              {% if item.original_price > item.final_price %}
                <del class="cart-item__original-price">{{ item.original_price | money }}</del>
              {% endif %}
              <span class="cart-item__final-price">{{ item.final_price | money }}</span>
              
              {%- comment -%} Show line-level discounts {%- endcomment -%}
              {% if item.line_level_discount_allocations.size > 0 %}
                <ul class="cart-item__discounts">
                  {% for discount_allocation in item.line_level_discount_allocations %}
                    <li class="cart-item__discount">
                      {{ discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </td>
            <td class="cart-item__quantity">
              <input type="number" name="updates[]" id="updates_{{ item.key }}" value="{{ item.quantity }}" min="0" aria-label="Quantity for {{ item.title }}">
            </td>
            <td class="cart-item__total">
              {% if item.original_line_price != item.final_line_price %}
                <del class="cart-item__original-total">{{ item.original_line_price | money }}</del>
              {% endif %}
              <strong class="cart-item__final-total">{{ item.final_line_price | money }}</strong>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    {%- comment -%} Cart-level discount display (Required) {%- endcomment -%}
    {% if cart.cart_level_discount_applications.size > 0 %}
      <div class="cart-discounts">
        <h3>Discounts</h3>
        <ul>
          {% for discount_application in cart.cart_level_discount_applications %}
            <li class="cart-discount">
              <span class="cart-discount__title">{{ discount_application.title }}</span>
              <span class="cart-discount__amount">-{{ discount_application.total_allocated_amount | money }}</span>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {%- comment -%} Cart Notes (Optional feature from settings) {%- endcomment -%}
    {% if settings.cart_notes_enable %}
      <div class="cart-note">
        <label for="cart-note">Order notes</label>
        <textarea name="note" id="cart-note" placeholder="Special instructions for your order">{{ cart.note }}</textarea>
      </div>
    {% endif %}

    <div class="cart-footer">
      <div class="cart-totals">
        <div class="cart-subtotal">
          <span>Subtotal:</span>
          <strong class="cart-subtotal__value">{{ cart.total_price | money }}</strong>
        </div>
        
        {%- comment -%} Tax-inclusive pricing message (Required) {%- endcomment -%}
        {% if cart.taxes_included %}
          <p class="cart-tax-message">Tax included</p>
        {% endif %}
        
        {% if cart.total_discount > 0 %}
          <div class="cart-savings">
            <span>You're saving:</span>
            <strong class="savings-amount">{{ cart.total_discount | money }}</strong>
          </div>
        {% endif %}
        
        {%- if cart.taxes_included -%}
          <p class="cart-tax-message">{{ 'sections.cart.taxes_included' | t | default: 'Tax included.' }}</p>
        {%- endif -%}
        
        <p class="cart-shipping-message">
          {%- if shop.shipping_policy.body != blank -%}
            {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url | default: 'Shipping and <a href="' | append: shop.shipping_policy.url | append: '">shipping policy</a> calculated at checkout.' }}
          {%- else -%}
            {{ 'sections.cart.shipping_at_checkout' | t | default: 'Shipping calculated at checkout.' }}
          {%- endif -%}
        </p>
      </div>

      <div class="cart-note-wrapper field">
        <label for="Cart-note" class="cart-note__label">{{ 'sections.cart.note' | t | default: 'Order note' }}</label>
        <textarea
          name="note"
          id="Cart-note"
          class="cart-note__input field__input"
          placeholder="{{ 'sections.cart.note_placeholder' | t | default: 'Special instructions for your order' }}"
        >{{ cart.note }}</textarea>
      </div>

      <div class="cart-actions">
        <button type="submit" name="update" class="btn btn-secondary">Update Cart</button>
        <button type="submit" name="checkout" class="btn btn-primary">Proceed to Checkout</button>
        
        {%- comment -%} Accelerated Checkout Buttons (Required - Must be enabled by default) {%- endcomment -%}
        <div class="cart-dynamic-checkout">
          {{ content_for_additional_checkout_buttons }}
        </div>
      </div>
    </div>
  </form>
{% else %}
  <div class="cart-empty">
    <h2>Your cart is empty</h2>
    <p>Start shopping to add items to your cart</p>
    <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">Continue Shopping</a>
  </div>
{% endif %}
</div>

<style>
  .cart-container {
    --cart-top-offset: 136px;
    max-width: 1200px;
    margin: var(--cart-top-offset) auto 48px;
    padding: 28px;
    background-color: var(--color-background);
    color: var(--color-text);
    border: 1px solid rgb(0 0 0 / 10%);
    box-shadow: 0 16px 34px rgb(0 0 0 / 8%);
  }

  .cart-container > h1 {
    margin: 0 0 24px;
    color: var(--color-text);
    font-family: var(--ff-mr_de_haviland);
    font-size: clamp(3.2rem, 4vw, 4.8rem);
    font-weight: var(--fw-500);
    line-height: 1;
  }

  .cart-note-wrapper {
    margin: 24px 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cart-note__label {
    font-weight: 600;
    font-size: 1.4rem;
  }

  .cart-note__input {
    min-height: 100px;
    padding: 12px;
    border: 1px solid rgb(0 0 0 / 15%);
    border-radius: 4px;
    resize: vertical;
  }

  .cart-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 30px;
  }

  .cart-table th,
  .cart-table td {
    padding: 15px 12px;
    text-align: left;
    border-bottom: 1px solid rgb(0 0 0 / 11%);
    vertical-align: top;
  }

  .cart-table th {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 1.15rem;
    letter-spacing: 0.08em;
    color: var(--color-text);
  }

  .cart-item__image img {
    width: 104px;
    height: auto;
    border: 1px solid rgb(0 0 0 / 10%);
    background-color: var(--color-background);
  }

  .cart-item__title {
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text);
    font-size: 1.1em;
    margin-bottom: 6px;
  }

  .cart-item__options {
    color: rgb(0 0 0 / 70%);
    font-size: 0.9em;
    margin: 5px 0;
  }
  .cart-item__option {
    display: flex;
    gap: 5px;
  }
  .cart-item__option dt {
    font-weight: 600;
    margin: 0;
  }
  .cart-item__option dd {
    margin: 0;
  }

  .cart-item__selling-plan {
    background: rgb(0 0 0 / 5%);
    padding: 8px;
    border: 1px solid rgb(0 0 0 / 9%);
    font-size: 0.9em;
    margin: 8px 0;
  }

  .cart-item__unit-price {
    font-size: 0.85em;
    color: rgb(0 0 0 / 70%);
    margin: 5px 0;
  }

  .cart-item__remove {
    color: var(--color-button);
    text-decoration: underline;
    font-size: 0.9em;
    cursor: pointer;
    margin-top: 8px;
  }

  .cart-item__original-price,
  .cart-item__original-total {
    text-decoration: line-through;
    color: rgb(0 0 0 / 55%);
    margin-right: 8px;
  }

  .cart-item__discounts {
    list-style: none;
    padding: 0;
    margin: 5px 0 0 0;
  }

  .cart-item__discount {
    color: var(--color-button);
    font-size: 0.85em;
    margin: 3px 0;
  }

  .cart-item__quantity input {
    width: 86px;
    padding: 8px;
    border: 1px solid rgb(0 0 0 / 16%);
    background-color: var(--color-background);
    color: var(--color-text);
    text-align: center;
  }

  .cart-discounts {
    background: rgb(0 0 0 / 3%);
    padding: 20px;
    border: 1px solid rgb(0 0 0 / 10%);
    margin-bottom: 20px;
  }

  .cart-discounts h3 {
    margin-top: 0;
    margin-bottom: 15px;
  }

  .cart-discounts ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cart-discount {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
  }

  .cart-discount__amount {
    color: var(--color-button);
    font-weight: 600;
  }

  .cart-note {
    margin: 20px 0;
    padding: 20px;
    border: 1px solid rgb(0 0 0 / 10%);
    background: rgb(0 0 0 / 2%);
  }

  .cart-note label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .cart-note textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid rgb(0 0 0 / 16%);
    background-color: var(--color-background);
    color: var(--color-text);
    resize: vertical;
    min-height: 80px;
    font-family: inherit;
  }

  .cart-footer {
    display: grid;
    grid-template-columns: 1fr minmax(290px, 360px);
    gap: 30px;
    margin-top: 30px;
    padding-top: 22px;
    border-top: 1px solid rgb(0 0 0 / 11%);
  }

  .cart-totals {
    padding: 20px;
    border: 1px solid rgb(0 0 0 / 10%);
    background: rgb(0 0 0 / 3%);
  }

  .cart-subtotal,
  .cart-savings {
    display: flex;
    justify-content: space-between;
    margin: 10px 0;
    font-size: 1.1em;
  }

  .cart-tax-message {
    color: rgb(0 0 0 / 70%);
    font-size: 0.9em;
    margin: 5px 0;
  }

  .cart-shipping-message {
    color: rgb(0 0 0 / 70%);
    font-size: 0.9em;
    margin: 10px 0;
  }

  .savings-amount {
    color: var(--color-button);
  }

  .cart-actions {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .cart-actions .btn {
    width: 100%;
    text-align: center;
  }

  .cart-dynamic-checkout {
    margin-top: 10px;
    padding: 14px;
    border: 1px solid rgb(0 0 0 / 10%);
    background: rgb(0 0 0 / 2%);
  }

  .cart-empty {
    text-align: center;
    padding: 70px 20px;
    border: 1px solid rgb(0 0 0 / 10%);
    background: rgb(0 0 0 / 3%);
  }

  .cart-empty h2 {
    margin-bottom: 15px;
    color: var(--color-text);
    font-family: var(--ff-mr_de_haviland);
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    font-weight: var(--fw-500);
  }

  .cart-empty p {
    color: rgb(0 0 0 / 70%);
    margin-bottom: 25px;
  }

  @media (max-width: 990px) {
    .cart-container {
      margin-bottom: 34px;
      padding: 20px;
    }

    .cart-footer {
      grid-template-columns: 1fr;
    }

    .cart-table {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }

    .cart-table {
      font-size: 0.9em;
    }

    .cart-table th,
    .cart-table td {
      padding: 10px 5px;
    }

    .cart-item__image img {
      width: 60px;
    }
  }

  @media (max-width: 575px) {
    .cart-container {
      padding: 16px;
    }
  }
</style>

<script>
  (function () {
    var moneyFormat = {{ shop.money_format | json }};

    function formatMoney(cents) {
      var value = Number(cents) || 0;
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        return window.Shopify.formatMoney(value, moneyFormat);
      }
      return (value / 100).toFixed(2);
    }

    function updateHeaderCartCount(itemCount) {
      var safeCount = Number(itemCount) || 0;
      document.querySelectorAll('[data-cart-count]').forEach(function (el) {
        el.textContent = safeCount;
        el.classList.toggle('is-hidden', safeCount === 0);
        el.setAttribute('aria-hidden', safeCount === 0 ? 'true' : 'false');
      });
    }

    function updateCartTotals(cart) {
      var subtotalValue = document.querySelector('.cart-subtotal__value');
      if (subtotalValue) {
        subtotalValue.innerHTML = formatMoney(cart.total_price);
      }

      var savingsAmount = document.querySelector('.savings-amount');
      if (savingsAmount) {
        var savingsValue = Number(cart.total_discount) || 0;
        savingsAmount.innerHTML = formatMoney(savingsValue);
        var savingsRow = savingsAmount.closest('.cart-savings');
        if (savingsRow) {
          savingsRow.style.display = savingsValue > 0 ? 'flex' : 'none';
        }
      }
    }

    function syncCartRows(cart) {
      var rows = document.querySelectorAll('.cart-item');
      rows.forEach(function (row, idx) {
        var item = cart.items[idx];
        if (!item) {
          row.remove();
          return;
        }

        row.dataset.line = String(idx + 1);

        var qtyInput = row.querySelector('.cart-item__quantity input[name="updates[]"]');
        if (qtyInput) qtyInput.value = item.quantity;

        var finalPrice = row.querySelector('.cart-item__final-price');
        if (finalPrice) finalPrice.innerHTML = formatMoney(item.final_price);

        var originalPrice = row.querySelector('.cart-item__original-price');
        if (originalPrice) {
          if (item.original_price > item.final_price) {
            originalPrice.style.display = '';
            originalPrice.innerHTML = formatMoney(item.original_price);
          } else {
            originalPrice.style.display = 'none';
          }
        }

        var finalTotal = row.querySelector('.cart-item__final-total');
        if (finalTotal) finalTotal.innerHTML = formatMoney(item.final_line_price);

        var originalTotal = row.querySelector('.cart-item__original-total');
        if (originalTotal) {
          if (item.original_line_price > item.final_line_price) {
            originalTotal.style.display = '';
            originalTotal.innerHTML = formatMoney(item.original_line_price);
          } else {
            originalTotal.style.display = 'none';
          }
        }
      });
    }

    function initCartQuantityUpdates() {
      var cartForm = document.querySelector('.cart-container form');
      if (!cartForm) return;
      if (cartForm.dataset.liveCartBound === 'true') return;
      cartForm.dataset.liveCartBound = 'true';

      var inFlight = false;
      var inputTimers = new WeakMap();

      function setQuantityInputsDisabled(disabled) {
        cartForm.querySelectorAll('.cart-item__quantity input[name="updates[]"]').forEach(function (input) {
          input.disabled = disabled;
        });
      }

      function updateLineQuantity(input) {
        if (inFlight) return;

        var row = input.closest('.cart-item');
        if (!row) return;

        var line = Number(row.dataset.line) || 0;
        if (!line) return;

        var quantity = Math.max(0, Number(input.value) || 0);
        input.value = quantity;

        inFlight = true;
        setQuantityInputsDisabled(true);

        fetch('/cart/change.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({
            line: line,
            quantity: quantity
          })
        })
          .then(function (response) {
            if (!response.ok) throw new Error('Cart update failed');
            return response.json();
          })
          .then(function (cart) {
            if (!cart || !Array.isArray(cart.items)) return;

            if ((Number(cart.item_count) || 0) === 0) {
              window.location.reload();
              return;
            }

            syncCartRows(cart);
            updateCartTotals(cart);
            updateHeaderCartCount(cart.item_count);
          })
          .catch(function (error) {
            console.error(error);
          })
          .finally(function () {
            inFlight = false;
            setQuantityInputsDisabled(false);
          });
      }

      cartForm.querySelectorAll('.cart-item__quantity input[name="updates[]"]').forEach(function (input) {
        input.addEventListener('input', function () {
          if (inputTimers.has(input)) {
            clearTimeout(inputTimers.get(input));
          }
          var timerId = setTimeout(function () {
            updateLineQuantity(input);
          }, 350);
          inputTimers.set(input, timerId);
        });

        input.addEventListener('change', function () {
          updateLineQuantity(input);
        });

        input.addEventListener('keydown', function (event) {
          if (event.key === 'Enter') {
            event.preventDefault();
            updateLineQuantity(input);
          }
        });
      });
    }

    function setCartTopOffset() {
      var cartContainer = document.querySelector('.cart-container');
      if (!cartContainer) return;

      var mainHeader = document.querySelector('header.header[data-header]');
      var announcement = document.querySelector('header[data-section-id] .alert');

      var headerHeight = mainHeader ? mainHeader.getBoundingClientRect().height : 0;
      var announcementHeight = announcement ? announcement.getBoundingClientRect().height : 0;
      var totalOffset = Math.max(96, Math.round(headerHeight + announcementHeight + 24));

      cartContainer.style.setProperty('--cart-top-offset', totalOffset + 'px');
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        setCartTopOffset();
        initCartQuantityUpdates();
      });
    } else {
      setCartTopOffset();
      initCartQuantityUpdates();
    }

    window.addEventListener('resize', setCartTopOffset);
    window.addEventListener('load', setCartTopOffset);
    document.addEventListener('shopify:section:load', function () {
      setCartTopOffset();
      initCartQuantityUpdates();
    });
  })();
</script>

