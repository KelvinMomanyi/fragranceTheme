<!-- 
  - #FEATURED POST
-->

{%- liquid
  assign blog_context = 'none'

  if section.settings.blog_type != blank
    assign current_blog = blogs[section.settings.blog_type]
    assign blog_context = 'selected'
  elsif blog != blank
    assign current_blog = blog
    assign blog_context = 'page'
  else
    assign current_blog = blogs['news']

    if current_blog != blank
      assign blog_context = 'news'
    endif
  endif
-%}

<section class="section featured" aria-label="featured post">
  <div class="container">

    <h1 class="section-title">
      {{ current_blog.title | default: section.settings.mainBlog_text | escape }}
    </h1>

    {% if blog_context == 'selected' %}
      {%- paginate blogs[section.settings.blog_type].articles by 12 -%}
        <ul class="blog-grid">
          {%- for article in current_blog.articles -%}
            <li class="blog-grid-item">
              <div class="blog-card">
                <figure class="card-banner img-holder" style="--width: 500; --height: 600;">
                  {%- if article.image -%}
                    <img src="{{ article.image | image_url: width: 1000 }}" 
                      srcset="{{ article.image | image_url: width: 500 }} 500w,
                              {{ article.image | image_url: width: 1000 }} 1000w"
                      sizes="(max-width: 768px) 100vw, 500px"
                      width="500" height="600" loading="lazy"
                      alt="{{ article.image.alt | escape }}" class="img-cover"/>
                  {%- else -%}
                     {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </figure>

                <div class="card-content">
                  <ul class="card-meta-list">
                    {%- for tag in article.tags -%}
                      <li>
                        <a href="{{ current_blog.url }}/tagged/{{ tag | handle }}" class="card-tag">{{ tag }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>

                  <h3 class="h4">
                    <a href="{{ article.url }}" class="card-title hover:underline">
                      {{ article.title }}
                    </a>
                  </h3>

                  <div class="card-text rte">
                    {{ article.excerpt_or_content | strip_html | truncatewords: 30 }}
                  </div>

                  <div class="card-footer-meta">
                    <span class="article-date">{{ article.published_at | date: "%b %d, %Y" }}</span>
                  </div>
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          <div class="pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    {% elsif blog_context == 'page' %}
    {%- paginate blog.articles by 12 -%}
      <ul class="blog-grid">
        {%- for article in current_blog.articles -%}
          <li class="blog-grid-item">
            <div class="blog-card">
              <figure class="card-banner img-holder" style="--width: 500; --height: 600;">
                {%- if article.image -%}
                  <img src="{{ article.image | image_url: width: 1000 }}" 
                    srcset="{{ article.image | image_url: width: 500 }} 500w,
                            {{ article.image | image_url: width: 1000 }} 1000w"
                    sizes="(max-width: 768px) 100vw, 500px"
                    width="500" height="600" loading="lazy"
                    alt="{{ article.image.alt | escape }}" class="img-cover"/>
                {%- else -%}
                   {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </figure>

              <div class="card-content">
                <ul class="card-meta-list">
                  {%- for tag in article.tags -%}
                    <li>
                      <a href="{{ current_blog.url }}/tagged/{{ tag | handle }}" class="card-tag">{{ tag }}</a>
                    </li>
                  {%- endfor -%}
                </ul>

                <h3 class="h4">
                  <a href="{{ article.url }}" class="card-title hover:underline">
                    {{ article.title }}
                  </a>
                </h3>

                <div class="card-text rte">
                  {{ article.excerpt_or_content | strip_html | truncatewords: 30 }}
                </div>

                <div class="card-footer-meta">
                  <span class="article-date">{{ article.published_at | date: "%b %d, %Y" }}</span>
                </div>
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if paginate.pages > 1 -%}
        <div class="pagination">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
    {% elsif blog_context == 'news' %}
      {%- paginate blogs['news'].articles by 12 -%}
        <ul class="blog-grid">
          {%- for article in current_blog.articles -%}
            <li class="blog-grid-item">
              <div class="blog-card">
                <figure class="card-banner img-holder" style="--width: 500; --height: 600;">
                  {%- if article.image -%}
                    <img src="{{ article.image | image_url: width: 1000 }}" 
                      srcset="{{ article.image | image_url: width: 500 }} 500w,
                              {{ article.image | image_url: width: 1000 }} 1000w"
                      sizes="(max-width: 768px) 100vw, 500px"
                      width="500" height="600" loading="lazy"
                      alt="{{ article.image.alt | escape }}" class="img-cover"/>
                  {%- else -%}
                     {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </figure>

                <div class="card-content">
                  <ul class="card-meta-list">
                    {%- for tag in article.tags -%}
                      <li>
                        <a href="{{ current_blog.url }}/tagged/{{ tag | handle }}" class="card-tag">{{ tag }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>

                  <h3 class="h4">
                    <a href="{{ article.url }}" class="card-title hover:underline">
                      {{ article.title }}
                    </a>
                  </h3>

                  <div class="card-text rte">
                    {{ article.excerpt_or_content | strip_html | truncatewords: 30 }}
                  </div>

                  <div class="card-footer-meta">
                    <span class="article-date">{{ article.published_at | date: "%b %d, %Y" }}</span>
                  </div>
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          <div class="pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    {% else %}
      <div class="collection-empty">
        <p>No blog is available to display here yet.</p>
      </div>
    {% endif %}

  </div>
</section>



{% schema %}
{
  "name": "Main blog",
  "settings": [
    {
      "type":"text",
      "id":"mainBlog_text",
      "label":"Main Blog Heading",
      "default":"Get started with our best stories"
     },
     {
      "type": "blog",
      "id": "blog_type",
      "label": "Select Blog Category"
     }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Main blog",
      "category": "Pages"
    }
  ]
}
{% endschema %}


