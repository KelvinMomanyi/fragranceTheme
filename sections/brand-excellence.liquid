<section class="section service color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}" id="service" aria-labelledby="service-lable">

  <p class="section-subtitle container" id="service-lable"></p>
  <div class="container">
    <ul class="service-list">

      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <li data-reveal {{ block.shopify_attributes }}>
            <div class="service-card container">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 680 }}" 
                     srcset="{{ block.settings.image | image_url: width: 340 }} 340w,
                             {{ block.settings.image | image_url: width: 680 }} 680w"
                     sizes="(max-width: 991px) 1px, 340px"
                     width="340" 
                     height="380" 
                     loading="lazy" 
                     alt="{{ block.settings.image.alt | default: block.settings.title }}"
                     class="img">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'img' }}
              {%- endif -%}
    
              <div>
                <h3 class="h3 card-title">{{ block.settings.title }}</h3>
                <p class="card-subtitle">{{ block.settings.description }}</p>
              </div>
    
              <a href="{{ block.settings.link }}" class="btn-icon" aria-label="See more">
                <svg xmlns="http://www.w3.org/2000/svg" width="43" height="20" viewBox="0 0 43 20" fill="none">
                  <path d="M0 10H41" stroke="black" stroke-width="2" />
                  <path d="M33 1L41.9 10.2727L33 19" stroke="black" stroke-width="2" />
                </svg>
              </a>
            </div>
          </li>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback for when no blocks exist {%- endcomment -%}
        {%- assign default_titles = "Fast Shipping, Secure Payments, Easy Returns, 24/7 Support" | split: ", " -%}
        {%- assign default_descs = "Global delivery in 3-5 business days., Your transactions are protected and encrypted., 30-day hassle-free return policy., Dedicated team to assist you anytime." | split: ", " -%}
        {%- for title in default_titles -%}
          <li data-reveal>
            <div class="service-card container">
              {{ 'product-1' | placeholder_svg_tag: 'img' }}
              <div>
                <h3 class="h3 card-title">{{ title }}</h3>
                <p class="card-subtitle">{{ default_descs[forloop.index0] }}</p>
              </div>
              <a href="#" class="btn-icon" aria-label="See more">
                <svg xmlns="http://www.w3.org/2000/svg" width="43" height="20" viewBox="0 0 43 20" fill="none">
                  <path d="M0 10H41" stroke="black" stroke-width="2" />
                  <path d="M33 1L41.9 10.2727L33 19" stroke="black" stroke-width="2" />
                </svg>
              </a>
            </div>
          </li>
        {%- endfor -%}
      {%- endif -%}

    </ul>

  </div>
  
</section>

<style>
.service { padding-inline: 15px; }

.service .section-subtitle {
  padding-inline: 10px;
  margin-block-end:75px;
}

.service-card .img { display: none; }

.service-list > li:not(:last-child) { border-block-start: 1px solid currentColor; }

.service-list > li:last-child { border-block: 1px solid currentColor; }

.service-card { padding: 30px 10px; }

.service-card .card-subtitle {
  color: inherit;
  font-size: var(--fs-7);
  font-weight: var(--fw-300);
  line-height: 1.5;
  margin-block: 10px 25px;
}

.service-card .btn-icon {
  width: 55px;
  height: 55px;
  border: 1px solid currentColor;
  --bg-color: transparent;
  --hover-bg-color: gray;
  --hover-text-color: var(--color-text);
}

.service-card .btn-icon svg { width: 25px; }

.img{
    width: 300px;
    height: 300px;
}


.btn-icon {
  background-color: var(--bg-color, transparent);
  border-radius: 50%;
  display: grid;
  place-content: center;
  transition: var(--transition-2);
}

.btn-icon path { transition: var(--transition-2); }

.btn-icon:is(:hover, :focus-visible) {
  background-color: var(--hover-bg-color, transparent);
}

.btn-icon:is(:hover, :focus-visible) path {
  stroke: var(--hover-text-color, currentColor);
}

@media (min-width: 768px){
 /**
   * SERVICE
   */

   .service-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .service-card .card-subtitle { margin-block-end: 15px; }   
}



@media (min-width: 992px){
/**
   * SERVICE
   */

   .service-card { position: relative; }

   .service-card .img {
     display: block;
     position: absolute;
     top: 50%;
     left: 50%;
     transform: translate(-50%, -50%);
     width: 200px;
     opacity: 0;
     visibility: hidden;
     transition: var(--transition-1);
     z-index: 1;
   }
 
   .service-card:is(:hover, :focus-within) .img {
     opacity: 1;
     visibility: visible;
   }
} 

@media (min-width: 1200px){
/**
   * SERVICE
   */

   .service-card { padding-block: 50px; }

   .service-card .card-subtitle { --fs-7: 2.4rem; }
 
   .service-card .img { width: max-content; }
 
   .service-card .btn-icon {
     width: 95px;
     height: 95px;
   }
 
   .service-card .btn-icon svg { width: 40px; }
 
}

@media (min-width: 1400px) {
    
  /**
   * SERVICE
   */

  .service { padding-inline: 70px; }

  .service-card { padding-block: 65px; }
}
</style>

{% schema %}
{
  "name": "Brand Excellence",
  "tag": "section",
  "class": "section service",
  "settings": [
    {
      "type": "color_scheme","id": "color_scheme","label": "Color scheme","default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "service_card",
      "name": "Service Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "340 x 380px recommended. Shows on hover (desktop only)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Luxury Perfumes"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Discover timeless scents crafted with elegance."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Excellence",
      "category": "Storytelling",
      "blocks": [
        {
          "type": "service_card",
          "settings": {
            "title": "Fast Shipping",
            "description": "Global delivery in 3-5 business days."
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "Secure Payments",
            "description": "Your transactions are protected and encrypted."
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "Easy Returns",
            "description": "30-day hassle-free return policy."
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "24/7 Support",
            "description": "Dedicated team to assist you anytime."
          }
        }
      ]
    }
  ]
}
{% endschema %}



