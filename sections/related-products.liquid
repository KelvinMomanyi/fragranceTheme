<div class="related-products section-{{ section.id }} color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}">
  {% if product.id %}
    <product-recommendations
      class="related-products__recommendations"
      data-url="{{ routes.product_recommendations_url }}?limit={{ section.settings.product_limit }}&intent=related"
      data-product-id="{{ product.id }}"
      data-section-id="{{ section.id }}"
    >
      {% if recommendations.performed and recommendations.products_count > 0 %}
        <div class="container">
          {%- if section.settings.heading != blank -%}
            <div class="title-wrapper">
              <h2 class="h2 section-title related-products__heading">{{ section.settings.heading }}</h2>
            </div>
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <p class="related-products__description">{{ section.settings.description }}</p>
          {%- endif -%}

          <ul class="related-products__grid" data-filter="all">
            {% for related_product in recommendations.products %}
              <li class="decoration">
                <div class="product-card">
                  <a href="{{ related_product.url }}" class="card-banner img-holder has-before" style="--width: 300; --height: 300;">
                    {% if related_product.featured_image %}
                      <img
                        src="{{ related_product.featured_image | image_url: width: 600 }}"
                        srcset="{{ related_product.featured_image | image_url: width: 300 }} 300w,
                                {{ related_product.featured_image | image_url: width: 450 }} 450w,
                                {{ related_product.featured_image | image_url: width: 600 }} 600w"
                        sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 300px"
                        alt="{{ related_product.featured_image.alt | escape }}"
                        class="img-cover"
                        style="{% render 'focal-point-style', image: related_product.featured_image %}"
                        width="300"
                        height="300"
                        loading="lazy"
                      >
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'img-cover' }}
                    {% endif %}

                    <ul class="card-action-list">
                      <li>
                        <button class="card-action-btn" aria-label="add to cart" title="add to cart">
                          {% render 'icon-velour', icon: 'add' %}
                        </button>
                      </li>
                      <li>
                        <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="add-to-cart-form" onsubmit="submitAddToCartForm(this); return false;">
                          <input type="hidden" name="id" value="{{ related_product.selected_or_first_available_variant.id }}">
                          <button type="submit" class="card-action-btn" aria-label="add to cart" title="add to cart">
                            {% render 'icon-velour', icon: 'bag-handle' %}
                          </button>
                        </form>
                      </li>
                    </ul>

                    {% if related_product.compare_at_price > related_product.price %}
                      <ul class="badge-list">
                        <li>
                          <div class="badge orange">Sale</div>
                        </li>
                        <li>
                          <div class="badge cyan">
                            {%- assign savings = related_product.compare_at_price | minus: related_product.price -%}
                            {%- assign savings_percent = savings | times: 100 | divided_by: related_product.compare_at_price -%}
                            {{ savings_percent }}%
                          </div>
                        </li>
                      </ul>
                    {% endif %}
                  </a>

                  <div class="card-content">
                    <h3 class="h3">
                      <a href="{{ related_product.url }}" class="card-title">{{ related_product.title }}</a>
                    </h3>
                    <div class="card-price">
                      {% if related_product.compare_at_price > related_product.price %}
                        <del class="del">{{ related_product.compare_at_price | money }}</del>
                      {% endif %}
                      {% if related_product.price_varies %}
                        <span class="price-from">From </span>
                      {% endif %}
                      <data class="price" value="{{ related_product.price }}">{{ related_product.price | money }}</data>
                    </div>
                    {% assign first_variant = related_product.selected_or_first_available_variant %}
                    {% if first_variant.unit_price_measurement %}
                      <div class="unit-price">
                        {{ first_variant.unit_price | money }}/{{ first_variant.unit_price_measurement.reference_value }}{{ first_variant.unit_price_measurement.reference_unit }}
                      </div>
                    {% endif %}
                  </div>
                </div>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </product-recommendations>
  {% endif %}
</div>

<style>
  .related-products {
    padding: var(--section-padding) 0;
  }

  .related-products__heading {
    text-align: center;
    margin-bottom: 0;
  }

  .related-products__description {
    text-align: center;
    font-size: var(--fs-4);
    color: var(--granite-gray);
    max-width: 62ch;
    margin: 0 auto 20px;
  }

  .related-products .title-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 8px;
  }

  .related-products__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 15px;
    padding-bottom: 10px;
    scrollbar-width: none;
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  .related-products__grid::-webkit-scrollbar {
    display: none;
  }

  .related-products__grid > li {
    flex: 0 0 calc(25% - 12px);
    scroll-snap-align: start;
  }

  .related-products .product-card {
    text-align: center;
    padding: 10px;
  }

  .related-products .card-action-btn {
    background-color: #ffffff;
    color: var(--smokey-black);
  }

  .related-products .badge.cyan {
    background-color: #000000;
    color: #ffffff;
  }

  .related-products .card-content {
    padding: 0;
  }

  .related-products .unit-price {
    margin-top: 6px;
    font-size: var(--fs-6);
    color: var(--spanish-gray);
  }

  @media (max-width: 1024px) {
    .related-products__grid > li {
      flex: 0 0 calc(33.33% - 10px);
    }
  }

  @media (max-width: 768px) {
    .related-products__grid > li {
      flex: 0 0 calc(50% - 8px);
    }
  }

  @media (max-width: 480px) {
    .related-products__grid > li {
      flex: 0 0 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Related products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Automatically generated product recommendations based on what customers browse together"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Maximum products to show",
      "default": 4
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Related products",
      "category": "Products"
    }
  ]
}
{% endschema %}
