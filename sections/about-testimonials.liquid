<section class="section about-testimonials color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}">
  <div class="container">
    <div class="about-testimonials__header">
      <h2 class="about-testimonials__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="about-testimonials__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="about-testimonials__grid">
      {%- for block in section.blocks -%}
        <article class="about-testimonials__card" {{ block.shopify_attributes }}>
          <p class="about-testimonials__quote">&ldquo;{{ block.settings.quote }}&rdquo;</p>
          <p class="about-testimonials__author">
            <span>{{ block.settings.author }}</span>
            {%- if block.settings.role != blank -%}
              <span class="about-testimonials__role">{{ block.settings.role }}</span>
            {%- endif -%}
          </p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .about-testimonials__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 32px;
  }

  .about-testimonials__title {
    font-size: var(--fs-2);
    margin: 0 0 12px;
    font-weight: var(--fw-500);
  }

  .about-testimonials__subtitle {
    opacity: 0.8;
    font-size: var(--fs-4);
  }

  .about-testimonials__grid {
    display: grid;
    gap: 22px;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .about-testimonials__card {
    border: 1px solid currentColor;
    padding: 24px 22px;
    background: var(--color-background);
    display: grid;
    gap: 12px;
  }

  .about-testimonials__quote {
    font-size: var(--fs-4);
    line-height: 1.7;
    margin: 0;
    font-style: italic;
  }

  .about-testimonials__author {
    margin: 0;
    display: grid;
    gap: 4px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--fs-6);
  }

  .about-testimonials__role {
    opacity: 0.7;
  }
</style>

{% schema %}
{
  "name": "About testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real notes from fragrance lovers."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "quote",
          "label": "Quote",
          "default": "The only store I trust for my signature scent."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Jane D."
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About testimonials",
      "category": "Storytelling",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}




