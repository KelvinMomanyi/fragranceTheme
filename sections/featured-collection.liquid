{%- comment -%}
  FEATURED COLLECTION SECTION
{%- endcomment -%}

<section class="section featured-collection color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}" id="featured-collection-{{ section.id }}" aria-label="featured collection" data-aos="fade-up">
  <div class="container">

    <div class="title-wrapper">
      <h2 class="h2 section-title">{{ section.settings.title | default: 'Popular Products' }}</h2>

      {% if section.blocks.size > 0 %}
        <ul class="filter-btn-list">
          {% for block in section.blocks %}
            <li class="filter-btn-item">
              <button class="filter-btn {% if forloop.first %}active{% endif %}" data-filter-btn="{{ block.id }}">{{ block.settings.title }}</button>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    <div class="product-sliders-container">
      {% for block in section.blocks %}
        <ul class="product-slider {% if forloop.first %}active{% else %}hidden{% endif %}" data-slider="{{ block.id }}">
          {% assign collection = collections[block.settings.collection] %}
          {% if collection and collection.products.size > 0 %}
            {% for product in collection.products limit: section.settings.products_to_show %}
              <li class="product-item">
                <div class="product-card">
                  <a href="{{ product.url }}" class="card-banner img-holder has-before" style="--width: 300; --height: 300;">
                    {% if product.featured_image %}
                      <img src="{{ product.featured_image | image_url: width: 600 }}" 
                        srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                                {{ product.featured_image | image_url: width: 450 }} 450w,
                                {{ product.featured_image | image_url: width: 600 }} 600w"
                        sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 25vw"
                        alt="{{ product.featured_image.alt | escape }}" 
                        class="img-cover" 
                        width="300" 
                        height="300" 
                        loading="lazy">
                        <ul class="card-action-list">
                          <li>
                            <button class="card-action-btn" aria-label="add to cart" title="add to cart">
                              {% render 'icon-velour', icon: 'add' %}
                            </button>
                          </li>
                          <li>
                            <form action="/cart/add" method="post" enctype="multipart/form-data" onsubmit="submitAddToCartForm(this); return false;">
                              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                              <button type="submit" class="card-action-btn" aria-label="add to cart" title="add to cart">
                                {% render 'icon-velour', icon: 'bag-handle' %}
                              </button>
                            </form>
                          </li>
                        </ul>
      
                        {% if product.compare_at_price > product.price %}
                        <ul class="badge-list">
                          <li>
                            <div class="badge cyan">Sale</div>
                          </li>
                        </ul>
                        {% endif %}
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'img-cover' }}
                    {% endif %}
                  </a>
                  <div class="card-content">
                    <h3 class="h3">
                      <a href="{{ product.url }}" class="card-title">{{ product.title }}</a>
                    </h3>
                    <div class="card-price">
                      {% if product.compare_at_price > product.price %}
                        <del class="del">{{ product.compare_at_price | money }}</del>
                      {% endif %}
                      <data class="price" value="{{ product.price }}">{{ product.price | money }}</data>
                    </div>
                  </div>
                </div>
              </li>
            {% endfor %}
          {% else %}
            {% for i in (1..section.settings.products_to_show) %}
              <li class="product-item">
                <div class="product-card">
                  <a href="#" class="card-banner img-holder has-before" style="--width: 300; --height: 300;">
                    {% assign placeholder_idx = i | modulo: 6 | plus: 1 %}
                    {{ 'product-' | append: placeholder_idx | placeholder_svg_tag: 'img-cover' }}
                  </a>
                  <div class="card-content">
                    <h3 class="h3">
                      <a href="#" class="card-title">Example Product {{ i }}</a>
                    </h3>
                    <div class="card-price">
                      <data class="price" value="19.99">$19.99</data>
                    </div>
                  </div>
                </div>
              </li>
            {% endfor %}
          {% endif %}
        </ul>
      {% endfor %}
      
      {% if section.blocks.size == 0 %}
        <ul class="product-slider active">
          {% for i in (1..section.settings.products_to_show) %}
            <li class="product-item">
              <div class="product-card">
                <a href="#" class="card-banner img-holder has-before" style="--width: 300; --height: 300;">
                  {% assign placeholder_idx = i | modulo: 6 | plus: 1 %}
                  {{ 'product-' | append: placeholder_idx | placeholder_svg_tag: 'img-cover' }}
                </a>
                <div class="card-content">
                  <h3 class="h3">
                    <a href="#" class="card-title">Example Product {{ i }}</a>
                  </h3>
                  <div class="card-price">
                    <data class="price" value="19.99">$19.99</data>
                  </div>
                </div>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    <div class="slider-nav">
      <button class="slider-prev" aria-label="Previous">&larr;</button>
      <button class="slider-next" aria-label="Next">&rarr;</button>
    </div>

  </div>
</section>

<style>
/* Filter Buttons */
.featured-collection .title-wrapper {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-bottom: 30px;
}
.featured-collection .filter-btn-list {
  display: flex;
  gap: 15px;
  list-style: none;
  padding: 0;
  margin: 15px 0 0 0;
  flex-wrap: wrap;
  justify-content: center;
}
.featured-collection .filter-btn {
  background: none;
  border: 1px solid var(--color-text, #000);
  padding: 8px 20px;
  cursor: pointer;
  color: var(--color-text, #000);
  transition: all 0.3s ease;
  border-radius: 20px;
}
.featured-collection .filter-btn.active, .featured-collection .filter-btn:hover {
  background: var(--color-text, #000);
  color: var(--color-background, #fff);
}

/* Products */
.featured-collection .product-slider.hidden {
  display: none !important;
}
.featured-collection .product-slider {
  display: flex;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  gap: 15px;
  padding-bottom: 10px;
  scrollbar-width: none;
  list-style: none;
  padding-left: 0;
  margin: 0;
}
.featured-collection .product-slider::-webkit-scrollbar {
  display: none;
}
.featured-collection .product-slider > li {
  flex: 0 0 calc(25% - 12px);
  scroll-snap-align: start;
}
.featured-collection .product-card {
  text-align: center;
  padding: 10px;
}
.featured-collection .slider-nav {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-top: 15px;
}
.featured-collection .slider-nav button {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--color-text, #000);
  color: var(--color-background, #fff);
  border: none;
  cursor: pointer;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s;
}
.featured-collection .slider-nav button:hover { opacity: 0.7; }

@media (max-width: 1024px) {
  .featured-collection .product-slider > li { flex: 0 0 calc(33.33% - 10px); }
}
@media (max-width: 768px) {
  .featured-collection .product-slider > li { flex: 0 0 calc(50% - 8px); }
  .featured-collection .title-wrapper { align-items: flex-start; }
  .featured-collection .filter-btn-list { justify-content: flex-start; }
}
@media (max-width: 480px) {
  .featured-collection .product-slider > li { flex: 0 0 100%; }
}
</style>

<script>
(function() {
  'use strict';
  document.addEventListener('DOMContentLoaded', function() {
    // Only target this specific section instance to avoid conflicts if used multiple times
    const section = document.getElementById('featured-collection-{{ section.id }}');
    if (!section) return;

    // Filter Buttons Logic
    const filterBtns = section.querySelectorAll('.filter-btn');
    const sliders = section.querySelectorAll('.product-slider');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', function() {
        // Remove active class from all buttons and sliders
        filterBtns.forEach(b => b.classList.remove('active'));
        sliders.forEach(s => {
          s.classList.remove('active');
          s.classList.add('hidden');
        });

        // Add active class to clicked button
        this.classList.add('active');

        // Show corresponding slider
        const targetId = this.getAttribute('data-filter-btn');
        const targetSlider = section.querySelector(`.product-slider[data-slider="${targetId}"]`);
        if (targetSlider) {
          targetSlider.classList.remove('hidden');
          targetSlider.classList.add('active');
        }
      });
    });

    // Slider Controls Logic
    const getScrollAmount = (slider) => {
      const firstItem = slider.querySelector('li');
      return firstItem ? firstItem.offsetWidth + 15 : 300;
    };

    section.addEventListener('click', function(event) {
      if (event.target.closest('.slider-next') || event.target.closest('.slider-prev')) {
        const activeSlider = section.querySelector('.product-slider.active');
        if (!activeSlider) return;

        if (event.target.closest('.slider-next')) {
          activeSlider.scrollBy({ left: getScrollAmount(activeSlider), behavior: 'smooth' });
        } else if (event.target.closest('.slider-prev')) {
          activeSlider.scrollBy({ left: -getScrollAmount(activeSlider), behavior: 'smooth' });
        }
      }
    });

  });
})();
</script>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Popular Products"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Maximum products to show"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "collection_section",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Title",
          "default": "Discover What's New"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL",
          "default": "/collections/all"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop All Products"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "category": "Custom",
      "blocks": [
        {
          "type": "collection_section",
          "settings": {
            "title": "Discover What's New",
            "collection": ""
          }
        },
        {
          "type": "collection_section",
          "settings": {
            "title": "Top Trending",
            "collection": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
