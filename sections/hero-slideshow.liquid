<section
  class="section hero-slideshow hero1 color-scheme-{{ section.settings.color_scheme }}"
  style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}"
  aria-label="Hero slideshow"
  data-hero-slideshow
>
  <ul class="hero1-slideshow" data-hero-slideshow-list>
    {% if section.blocks.size == 0 %}
      {% for i in (1..3) %}
        <li class="slideshow-item {% if forloop.first %}active{% endif %}" data-hero-slideshow-item>
          <div class="slideshow-bg hero1-card has-bg-image" style="background-color: #f4f4f4;">
            {{ 'lifestyle-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
          <div class="container">
            <div class="card-content">
              <h1 class="h1 hero1-title slideshow-reveal">Velour Scent {{ i }}</h1>
              <p class="price slideshow-reveal">Starting at $17.99</p>
              <div class="hero1-actions">
                <a href="#" class="btn btn-primary slideshow-reveal">Shop now</a>
              </div>
            </div>
          </div>
        </li>
      {% endfor %}
    {% else %}
      {% for block in section.blocks %}
        {% if block.type == 'slide' %}
          <li class="slideshow-item {% if forloop.first %}active{% endif %}" data-hero-slideshow-item {{ block.shopify_attributes }}>
            <div class="slideshow-bg hero1-card has-bg-image" style="{% if block.settings.hero_image != blank %}background-image: url('{{ block.settings.hero_image | image_url }}');{% else %}background-color: #f4f4f4;{% endif %} background-size: cover; background-repeat: no-repeat; background-position: center;">
              {% if block.settings.hero_image == blank %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <div class="container">
              <div class="card-content">
                <h1 class="h1 hero1-title slideshow-reveal">{{ block.settings.brand_name }}</h1>
                {% if block.settings.starting_price != blank %}
                  <p class="price slideshow-reveal">Starting at {{ block.settings.starting_price }}</p>
                {% endif %}
                {% if block.settings.button_label != blank %}
                  <div class="hero1-actions">
                    <a href="{{ block.settings.button_link }}" class="btn btn-primary slideshow-reveal">{{ block.settings.button_label }}</a>
                  </div>
                {% endif %}
              </div>
            </div>
          </li>
        {% endif %}
      {% endfor %}
    {% endif %}
  </ul>

  <button class="slideshow-btn prev" aria-label="slide to previous" data-prev-btn>
    {% render 'icon-velour', icon: 'chevron-back' %}
  </button>

  <button class="slideshow-btn next" aria-label="slide to next" data-next-btn>
    {% render 'icon-velour', icon: 'chevron-forward' %}
  </button>
</section>

<style>
  .hero-slideshow {
    position: relative;
    min-height: clamp(360px, 70vh, 640px);
    padding-block: clamp(70px, 10vw, 140px);
    overflow: hidden;
    color: var(--color-text);
  }

  .hero-slideshow .hero1-slideshow {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero-slideshow .slideshow-item {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: var(--transition-2);
  }

  .hero-slideshow .slideshow-item.active {
    opacity: 1;
    visibility: visible;
  }

  .hero-slideshow .slideshow-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    transform: scale(1.05);
  }

  .hero-slideshow .slideshow-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  .hero-slideshow .slideshow-item.active .slideshow-bg {
    animation: heroSlideshowScale 7s linear forwards;
  }

  @keyframes heroSlideshowScale {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.12);
    }
  }

  .hero-slideshow .container {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .hero-slideshow .card-content {
    max-width: 520px;
    display: grid;
    gap: 14px;
  }

  .hero-slideshow .hero1-title {
    font-size: clamp(3.2rem, 6vw, 6.6rem);
    line-height: 1.05;
    font-weight: var(--fw-500);
    color: #fff !important;
  }

  .hero-slideshow .price {
    color: #fff !important;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: var(--fs-6);
  }

  .hero-slideshow .hero1-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .hero-slideshow .slideshow-reveal {
    transform: translateY(24px);
    opacity: 0;
  }

  .hero-slideshow .slideshow-item.active .slideshow-reveal {
    animation: heroSlideshowReveal 0.9s ease forwards;
  }

  @keyframes heroSlideshowReveal {
    0% {
      transform: translateY(24px);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .hero-slideshow .slideshow-item.active .hero1-title {
    animation-delay: 200ms;
  }

  .hero-slideshow .slideshow-item.active .price {
    animation-delay: 400ms;
  }

  .hero-slideshow .slideshow-item.active .btn {
    animation-delay: 600ms;
  }

  .hero-slideshow .slideshow-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.35);
    color: #fff;
    border: 1px solid #fff;
    cursor: pointer;
    z-index: 2;
    transition: var(--transition-1);
  }

  .hero-slideshow .slideshow-btn:hover {
    background: #fff;
    color: #000;
  }

  .hero-slideshow .slideshow-btn.prev {
    left: 20px;
  }

  .hero-slideshow .slideshow-btn.next {
    right: 20px;
  }

  @media (max-width: 749px) {
    .hero-slideshow .slideshow-btn {
      display: none;
    }

    .hero-slideshow {
      padding-block: calc(var(--section-padding) * 2);
    }
  }
</style>

<script>
(function() {
  'use strict';

  document.querySelectorAll('[data-hero-slideshow]').forEach((root) => {
    const heroSlideshowItems = root.querySelectorAll('[data-hero-slideshow-item]');
    if (!heroSlideshowItems.length) {
      return;
    }

    const heroSlideshowPrevBtn = root.querySelector('[data-prev-btn]');
    const heroSlideshowNextBtn = root.querySelector('[data-next-btn]');

    let currentSlidePos = 0;
    let lastActiveSlideshowItem = heroSlideshowItems[0];

    const updateSlideshowPos = function() {
      lastActiveSlideshowItem.classList.remove('active');
      heroSlideshowItems[currentSlidePos].classList.add('active');
      lastActiveSlideshowItem = heroSlideshowItems[currentSlidePos];
    };

    const slideNext = function() {
      currentSlidePos = (currentSlidePos >= heroSlideshowItems.length - 1) ? 0 : currentSlidePos + 1;
      updateSlideshowPos();
    };

    const slidePrev = function() {
      currentSlidePos = (currentSlidePos < 1) ? heroSlideshowItems.length - 1 : currentSlidePos - 1;
      updateSlideshowPos();
    };

    if (heroSlideshowPrevBtn) {
      heroSlideshowPrevBtn.addEventListener('click', slidePrev);
    }

    if (heroSlideshowNextBtn) {
      heroSlideshowNextBtn.addEventListener('click', slideNext);
    }

    let autoSlideInterval;
    const autoSlide = function() {
      autoSlideInterval = setInterval(slideNext, 5000);
    };

    const stopAutoSlide = function() {
      clearInterval(autoSlideInterval);
    };

    root.addEventListener('mouseenter', stopAutoSlide);
    root.addEventListener('mouseleave', autoSlide);

    [heroSlideshowNextBtn, heroSlideshowPrevBtn].forEach((btn) => {
      if (!btn) {
        return;
      }
      btn.addEventListener('mouseenter', stopAutoSlide);
      btn.addEventListener('mouseleave', autoSlide);
    });

    window.addEventListener('load', autoSlide, { once: true });
  });
})();
</script>

{% schema %}
{
  "name": "Hero slideshow",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "hero_section",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "hero_image",
          "label": "Hero image",
          "info": "1920 x 1080px recommended"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Heading",
          "default": "Nike"
        },
        {
          "type": "text",
          "id": "starting_price",
          "label": "Starting price",
          "default": "$17.99"
        },
        {
          "type": "url",
          "id": "shop_now_link",
          "label": "Button link",
          "default": "/"
        },
        {
          "type": "text",
          "id": "shop_now_text",
          "label": "Button label",
          "default": "Shop now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slideshow",
      "blocks": [
        {
          "type": "hero_section",
          "settings": {
            "brand_name": "Signature Scents",
            "starting_price": "$17.99",
            "shop_now_link": "/collections/all",
            "shop_now_text": "Shop now"
          }
        },
        {
          "type": "hero_section",
          "settings": {
            "brand_name": "Fresh Arrivals",
            "starting_price": "$21.99",
            "shop_now_link": "/collections/all",
            "shop_now_text": "Shop now"
          }
        },
        {
          "type": "hero_section",
          "settings": {
            "brand_name": "Best Sellers",
            "starting_price": "$19.99",
            "shop_now_link": "/collections/all",
            "shop_now_text": "Shop now"
          }
        }
      ]
    }
  ]
}
{% endschema %}





