<section class="section about-collections color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}">
  <div class="container">
    <div class="about-collections__header">
      <h2 class="about-collections__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="about-collections__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="about-collections__grid">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        {%- assign card_title = block.settings.title -%}
        {%- assign card_text = block.settings.description -%}
        {%- assign card_image = block.settings.image -%}
        {%- assign card_link = block.settings.link -%}

        {%- if collection != blank -%}
          {%- assign card_title = card_title | default: collection.title -%}
          {%- assign card_text = card_text | default: collection.description -%}
          {%- assign card_image = card_image | default: collection.image -%}
          {%- assign card_link = collection.url -%}
        {%- endif -%}

        <article class="about-collections__card" {{ block.shopify_attributes }}>
          <a href="{{ card_link | default: '#' }}">
            <div class="about-collections__media">
              {%- if card_image != blank -%}
                <img
                  src="{{ card_image | image_url: width: 900 }}"
                  srcset="{{ card_image | image_url: width: 300 }} 300w,
                          {{ card_image | image_url: width: 600 }} 600w,
                          {{ card_image | image_url: width: 900 }} 900w,
                          {{ card_image | image_url: width: 1200 }} 1200w"
                  sizes="(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw"
                  alt="{{ card_image.alt | escape }}"
                  loading="lazy"
                  width="{{ card_image.width }}"
                  height="{{ card_image.height }}"
                >
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="about-collections__content">
              <h3>{{ card_title }}</h3>
              {%- if section.settings.show_description and card_text != blank -%}
                <p>{{ card_text | strip_html | truncate: 120 }}</p>
              {%- endif -%}
              {%- if block.settings.cta_label != blank -%}
                <span class="about-collections__cta">{{ block.settings.cta_label }}</span>
              {%- endif -%}
            </div>
          </a>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .about-collections__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 32px;
  }

  .about-collections__title {
    font-size: var(--fs-2);
    margin: 0 0 12px;
    font-weight: var(--fw-500);
  }

  .about-collections__subtitle {
    opacity: 0.8;
    font-size: var(--fs-4);
  }

  .about-collections__grid {
    display: grid;
    gap: 24px;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .about-collections__card a {
    display: grid;
    gap: 12px;
    color: inherit;
    border: 1px solid currentColor;
    padding: 16px;
    background: var(--color-background);
    transition: transform var(--transition-1);
  }

  .about-collections__media img,
  .about-collections__media .placeholder-svg {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-1);
  }

  .about-collections__media {
    overflow: hidden;
  }

  .about-collections__content {
    display: grid;
    gap: 8px;
    text-align: center;
  }

  .about-collections__content h3 {
    margin: 0;
    font-size: var(--fs-4);
    font-weight: var(--fw-500);
    font-family: var(--ff-roboto);
  }

  .about-collections__content p {
    margin: 0;
    opacity: 0.8;
  }

  .about-collections__cta {
    text-transform: uppercase;
    font-size: 1.2rem;
    letter-spacing: 0.12em;
    color: var(--color-button) !important;
  }

  .about-collections__card a:hover {
    transform: translateY(-2px);
  }

  .about-collections__card a:hover .about-collections__media img {
    transform: scale(1.02);
  }
</style>

{% schema %}
{
  "name": "Collection list",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore signature scents for every moment."
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title override"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description override"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Shop collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "category": "Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}




