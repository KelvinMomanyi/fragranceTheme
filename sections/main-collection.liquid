              "id": "products_per_row",
              "label": "Products per row (medium and large screens)",
              "min": 3,
              "max": 6,
              "step": 1,
              "default": 4
            },
            {
              "type": "checkbox",
              "id": "enable_filtering",
              "default": true,
              "label": "Enable filtering"
            },
            {
              "type": "select",
