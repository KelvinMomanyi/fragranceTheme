{%- liquid
  assign collection_context = 'none'

  if section.settings.selected_collection != blank
    assign current_collection = collections[section.settings.selected_collection]
    assign collection_context = 'selected'
  elsif collection != blank
    assign current_collection = collection
    assign collection_context = 'page'
  else
    assign current_collection = collections['all']

    if current_collection != blank
      assign collection_context = 'all'
    endif
  endif
-%}

{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-facets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'facets.js' | asset_url }}" type="module"></script>

<div class="container color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %} padding-top:25px;">
  {%- comment -%} Collection Hero with Image {%- endcomment -%}
  {% if current_collection.image %}
    <div class="collection-hero">
      <img
        src="{{ current_collection.image | image_url: width: 1600 }}"
        srcset="{{ current_collection.image | image_url: width: 750 }} 750w,
                {{ current_collection.image | image_url: width: 1100 }} 1100w,
                {{ current_collection.image | image_url: width: 1500 }} 1500w,
                {{ current_collection.image | image_url: width: 1780 }} 1780w,
                {{ current_collection.image | image_url: width: 2000 }} 2000w"
        sizes="100vw"
        alt="{{ current_collection.image.alt | escape | default: current_collection.title }}"
        class="collection-hero-image"
        style="{% render 'focal-point-style', image: current_collection.image %}"
        loading="eager"
        width="1600"
        height="400"
      >
      <div class="collection-hero-overlay">
        <h1 class="collection-hero-title">{{ current_collection.title }}</h1>
      </div>
    </div>
  {% endif %}

  <section class="section shop" id="shop" aria-label="shop">
    <div class="title-wrapper">
      {% unless current_collection.image %}
        <h1 class="h2 section-title">{{ current_collection.title }}</h1>
      {% endunless %}
    </div>

    {%- comment -%} Collection Description {%- endcomment -%}
    {% if current_collection.description != blank %}
      <div class="collection-description rte">
        {{ current_collection.description }}
      </div>
    {% endif %}

    <div class="section-{{ section.id }}-padding">
      {% if collection_context == 'selected' %}
        {% paginate collections[section.settings.selected_collection].products by 24 %}
          {% render 'main-collection-grid', current_collection: current_collection, section: section, paginate: paginate %}
        {% endpaginate %}
      {% elsif collection_context == 'page' %}
        {% paginate collection.products by 24 %}
          {% render 'main-collection-grid', current_collection: current_collection, section: section, paginate: paginate %}
        {% endpaginate %}
      {% elsif collection_context == 'all' %}
        {% paginate collections['all'].products by 24 %}
          {% render 'main-collection-grid', current_collection: current_collection, section: section, paginate: paginate %}
        {% endpaginate %}
      {% else %}
        <div class="collection-empty">
          <p>No collection is available to display here yet.</p>
        </div>
      {% endif %}
    </div>
  </section>
</div>

<style>
  .collection-hero {
    position: relative;
    width: 100%;
    height: 300px;
    border-radius: 0;
    overflow: hidden;
    margin-bottom: 30px;
  }

  .collection-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--focal-point, center center);
  }

  .collection-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 30px;
  }

  .collection-hero-title {
    color: white;
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
  }

  .collection-description {
    margin-bottom: 30px;
    line-height: 1.7;
    color: #555;
  }

  .collection-empty {
    text-align: center;
    padding: 60px 20px;
    background: #f8f9fa;
    border-radius: 12px;
    margin: 40px 0;
  }

  .collection-empty p {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 20px;
  }



  .card {
      background-color: #fff;
      border-radius: 10px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      opacity: 0;
      transform: translateY(50px);
      transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .card.in-view {
      opacity: 1;
      transform: translateY(0);
  }

  .card img {
      width: 100%;
      height: auto;
  }

  .card-content {
      padding: 20px;
  }

  .card h3 {
      margin: 0 0 10px;
  }

  .card p {
      margin: 0;
      color: #666;
  }

  .title-wrapper {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      gap: 1.5rem;
      flex-wrap: wrap;
  }

  @media (max-width: 768px) {
      .title-wrapper {
          flex-direction: column;
          align-items: flex-start;
      }
  }

.strategic-product-count {
  margin: 0;
  font-size: 1.4rem;
  font-weight: 500;
  color: var(--black);
  opacity: 0.7;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.product-count__text {
  font-family: var(--ff-roboto) !important;
  font-size: inherit !important;
  margin: 0;
}

  .collection-grid--adjustable {
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .collection-grid-topbar {
    margin: 0 0 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--black_25);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 14px;
  }

  .collection-grid-topbar .strategic-product-count {
    flex: 1 1 auto;
    min-width: 0;
  }

  .collection-grid-controls {
    --collection-grid-icon-stroke-width: 0.42;
    display: inline-flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 6px;
    margin: 0 0 0 auto;
    padding: 4px 8px;
    border: 0;
    background-color: color-mix(in srgb, var(--black) 3%, transparent);
  }

  .collection-grid-controls::before {
    content: 'View';
    display: inline-flex;
    align-items: center;
    padding-right: 6px;
    margin-right: 0;
    border-right: 0;
    color: var(--black);
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1;
    opacity: 0.65;
    white-space: nowrap;
  }

  .collection-grid-controls__group {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .collection-grid-controls__option {
    width: 30px;
    height: 30px;
    border: 0;
    background: transparent;
    color: var(--black);
    opacity: 0.62;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
  }

  .collection-grid-controls__option:hover {
    opacity: 0.86;
    border-color: transparent;
    background-color: color-mix(in srgb, var(--black) 7%, transparent);
  }

  .collection-grid-controls__option:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--black) 38%, transparent);
    outline-offset: 1px;
  }

  .collection-grid-controls__option.is-selected {
    opacity: 0.95;
    border-color: transparent;
    background-color: color-mix(in srgb, var(--black) 13%, transparent);
  }

  .collection-grid-controls__option:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    background-color: transparent;
  }

  .collection-grid-controls__icon {
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .collection-grid-controls__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
  }

  .collection-grid-controls__icon svg rect {
    fill: none;
    stroke-width: var(--collection-grid-icon-stroke-width);
    vector-effect: non-scaling-stroke;
  }

  .collection .product-card .card-price {
    display: inline-flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.55rem;
    margin-top: 0.2rem;
    color: var(--smokey-black);
  }

  .collection .product-card .card-price .price--current {
    font-size: 1.5rem;
    font-weight: var(--fw-600);
    letter-spacing: 0.01em;
    line-height: 1;
    color: var(--smokey-black);
  }

  .collection .product-card .card-price .price--compare {
    font-size: 1.2rem;
    line-height: 1;
    color: var(--spanish-gray);
    text-decoration-thickness: 1.5px;
    text-decoration-color: color-mix(in srgb, var(--spanish-gray) 75%, transparent);
  }

  .collection-layout--horizontal.collection-layout--has-facets {
    --collection-toolbar-border: transparent;
    --collection-toolbar-border-strong: transparent;
    --collection-toolbar-surface: color-mix(in srgb, var(--black) 3%, transparent);
    --collection-toolbar-surface-hover: color-mix(in srgb, var(--black) 7%, transparent);
    --collection-toolbar-surface-active: color-mix(in srgb, var(--black) 12%, transparent);
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    column-gap: 1.4rem;
    row-gap: 1rem;
  }

  .collection-layout--horizontal.collection-layout--has-facets > .facets-wrapper {
    grid-column: 1;
    min-width: 0;
    overflow: visible;
  }

  .collection-layout--horizontal.collection-layout--has-facets > .product-grid-container {
    grid-column: 1 / -1;
  }

  .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets-block-wrapper {
    margin-bottom: 0;
  }

  .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar {
    grid-column: 2;
    margin: 0;
    padding: 7px 10px;
    border: 0;
    background-color: var(--collection-toolbar-surface);
    white-space: nowrap;
    flex-wrap: nowrap;
    gap: 8px;
    min-height: 44px;
  }

  .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar .strategic-product-count {
    font-size: 0.96rem;
    letter-spacing: 0.02em;
    opacity: 0.72;
  }

  .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar .collection-grid-controls {
    padding: 4px 6px;
    gap: 4px;
  }

  .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar .collection-grid-controls::before {
    display: none;
    content: none;
  }

  @media screen and (min-width: 750px) {
    #main-collection-filters .facets--horizontal {
      z-index: 2;
    }

    #main-collection-filters .facets--horizontal .facets__panel-content {
      z-index: 3;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets-toggle {
      display: none;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal {
      display: flex;
      padding-block: 0;
      gap: 10px;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__form-wrapper {
      flex-direction: row;
      width: 100%;
      min-width: 0;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__form {
      flex-flow: row wrap;
      align-items: center;
      gap: 10px;
      width: 100%;
      min-width: 0;
      overflow: visible;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__filters-wrapper {
      flex: 1 1 auto;
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px;
      min-width: 0;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__item {
      border-bottom: 0;
      position: relative;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal details.facets__panel {
      padding: 0;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal summary.facets__summary {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 11px;
      min-height: 34px;
      border: 0;
      background-color: var(--collection-toolbar-surface);
      white-space: nowrap;
      transition: border-color 0.2s ease, background-color 0.2s ease;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .icon-caret .icon,
    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .sorting-filter .icon-caret .icon {
      font-size: 16px;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__label {
      font-size: 1.1rem;
      letter-spacing: 0.02em;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__status {
      font-size: 1rem;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal summary.facets__summary:hover {
      background-color: var(--collection-toolbar-surface-hover);
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal details[open] > summary.facets__summary {
      background-color: var(--collection-toolbar-surface-active);
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__panel-content {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      width: max-content;
      min-width: min(var(--facets-panel-min, 300px), 92vw);
      max-width: min(var(--facets-panel-max, 420px), 92vw);
      padding: 16px;
      border: 0;
      background: var(--white);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.14);
      z-index: 3;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__item details[open] {
      z-index: 4;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .sorting-filter__container {
      padding: 0;
      margin-inline-end: 0;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .sorting-filter__container .facets__label {
      display: none;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .sorting-filter__select-wrapper {
      min-height: 34px;
      border: 0;
      background-color: var(--collection-toolbar-surface);
      padding: 7px 10px;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .sorting-filter .facets__panel {
      position: relative;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .sorting-filter__options {
      left: auto;
      right: 0;
      top: calc(100% + 8px);
      min-width: 220px;
      z-index: 5;
    }

    .collection-grid-topbar {
      gap: 1rem 1.2rem;
    }

    .collection-grid-controls {
      padding: 4px 8px;
    }

    .collection-grid-controls__option {
      width: 30px;
      height: 30px;
    }

    .collection-grid-controls__icon {
      width: 20px;
      height: 20px;
    }

    .collection-grid--adjustable {
      grid-template-columns: repeat(var(--products-per-row, 4), minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 750px) and (max-width: 1099px) {
    .collection-layout--horizontal.collection-layout--has-facets {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
      row-gap: 12px;
    }

    .collection-layout--horizontal.collection-layout--has-facets > .facets-wrapper,
    .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar,
    .collection-layout--horizontal.collection-layout--has-facets > .product-grid-container {
      grid-column: 1;
    }

    .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar {
      width: 100%;
      justify-content: space-between;
      white-space: normal;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__form,
    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .facets__filters-wrapper {
      gap: 8px;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal summary.facets__summary {
      min-height: 36px;
      padding: 7px 11px;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets--horizontal .icon-caret .icon,
    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .sorting-filter .icon-caret .icon {
      font-size: 14px;
    }

    .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar .collection-grid-controls {
      padding: 5px 7px;
    }

    .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar .collection-grid-controls__option {
      width: 30px;
      height: 30px;
    }

    .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar .collection-grid-controls__icon {
      width: 16px;
      height: 16px;
    }
  }

  @media screen and (max-width: 749px) {
    .collection-layout--horizontal.collection-layout--has-facets {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .collection-layout--horizontal.collection-layout--has-facets > .facets-wrapper,
    .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar,
    .collection-layout--horizontal.collection-layout--has-facets > .product-grid-container {
      width: 100%;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets-block-wrapper {
      display: none;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets-toggle {
      display: flex;
      margin-bottom: 0;
      padding: 0;
      border: 0;
      background: transparent;
      height: auto;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets-toggle__wrapper {
      width: 100%;
    }

    .collection-layout--horizontal.collection-layout--has-facets #main-collection-filters .facets-toggle__button {
      width: 100%;
      min-height: 42px;
      justify-content: center;
      padding: 10px 14px;
      border: 0;
      background-color: color-mix(in srgb, var(--black) 3%, transparent);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-size: 1rem;
    }

    .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar {
      margin: 0;
      padding: 8px 10px;
      border: 0;
      background-color: color-mix(in srgb, var(--black) 3%, transparent);
      white-space: normal;
      gap: 8px;
    }

    .collection-layout--horizontal.collection-layout--has-facets > .collection-grid-topbar--toolbar .strategic-product-count {
      font-size: 0.92rem;
      letter-spacing: 0.02em;
      opacity: 0.7;
    }

    .collection-grid-controls {
      display: none;
    }
  }

  @media screen and (min-width: 750px) {
    .facets-vertical {
      display: flex;
      gap: 2rem;
    }

    .facets-vertical .facets-wrapper {
      flex: 0 0 280px;
      max-width: 280px;
    }

    .facets-vertical .product-grid-container {
      flex: 1;
      min-width: 0;
    }
  }
</style>

<script src="{{ 'collection.js' | asset_url }}" defer></script>

 {% schema %}
      {
        "name": "Main collection",
        "settings": [
            {
              "type": "color_scheme","id": "color_scheme","label": "Color scheme","default": "scheme-1"
            },
            {
             "type": "collection",
             "id": "selected_collection",
             "label": "Select Collection"
           },
            {
              "type": "range",
              "id": "products_per_row",
              "label": "Products per row (medium and large screens)",
              "min": 3,
              "max": 6,
              "step": 1,
              "default": 4
            },
            {
              "type": "checkbox",
              "id": "enable_filtering",
              "default": true,
              "label": "Enable filtering"
            },
            {
              "type": "select",
              "id": "filter_type",
              "options": [
                {
                  "value": "horizontal",
                  "label": "Horizontal"
                },
                {
                  "value": "vertical",
                  "label": "Vertical"
                },
                {
                  "value": "drawer",
                  "label": "Drawer"
                }
              ],
              "default": "horizontal",
              "label": "Filter type"
            },
            {
              "type": "checkbox",
              "id": "enable_sorting",
              "default": true,
              "label": "Enable sorting"
            }
        ],
        "blocks": [],
        "presets": [
          {
            "name": "Main collection",
            "category": "Pages"
          }
        ]
      }
 {% endschema %}




