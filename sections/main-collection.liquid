                },
                {
                  "value": "vertical",
                  "label": "Vertical"
                },
                {
                  "value": "drawer",
                  "label": "Drawer"
                }
              ],
              "default": "horizontal",
              "label": "Filter type"
            },
            {
              "type": "checkbox",
              "id": "enable_sorting",
