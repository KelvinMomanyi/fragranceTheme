<div class="best-sellers color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}" data-best-sellers>
<!-- Hero Section with Slider -->
<section class="hero1 text-center best-sellers__hero" aria-label="home" id="home">
  <ul class="hero1-slider" data-hero-slider>
    {% if section.blocks.size == 0 %}
      {% for i in (1..3) %}
        <li class="slider-item {% if forloop.first %}active{% endif %}" data-hero-slider-item>
          <div class="slider-bg hero1-card has-bg-image" style="background-color: #f4f4f4;">
            {{ 'lifestyle-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
          <div class="container">
            <div class="card-content">
              <h1 class="h1 hero1-title slider-reveal">Velour Scent {{ i }}</h1>
              <p class="price slider-reveal">Starting at $17.99</p>
              <div class="hero1-actions">
                <a href="#" class="btn btn-primary slider-reveal">Shop Now</a>
              </div>
            </div>
          </div>
        </li>
      {% endfor %}
    {% else %}
      {% for block in section.blocks %}
        {% if block.type == 'hero_section' %}
          <li class="slider-item {% if forloop.first %}active{% endif %}" data-hero-slider-item>
            <div class="slider-bg hero1-card has-bg-image" style="{% if block.settings.hero_image != blank %}background-image: url('{{ block.settings.hero_image | image_url }}');{% else %}background-color: #f4f4f4;{% endif %} background-size: cover; background-repeat: no-repeat; background-position: center;">
              {% if block.settings.hero_image == blank %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
            <div class="container">
              <div class="card-content">
                <h1 class="h1 hero1-title slider-reveal">{{ block.settings.brand_name }}</h1>
                <p class="price slider-reveal">Starting at {{ block.settings.starting_price }}</p>
                <div class="hero1-actions">
                  <a href="{{ block.settings.shop_now_link }}" class="btn btn-primary slider-reveal">{{ block.settings.shop_now_text }}</a>
                </div>
              </div>
            </div>
          </li>
        {% endif %}
      {% endfor %}
    {% endif %}
  </ul>

  <button class="slider-btn prev" aria-label="slide to previous" data-prev-btn>
    {% render 'icon-velour', icon: 'chevron-back' %}
  </button>

  <button class="slider-btn next" aria-label="slide to next" data-next-btn>
    {% render 'icon-velour', icon: 'chevron-forward' %}
  </button>
</section>

<!-- Best Sellers Products -->
<section class="section best-sellers__products">
  <div class="container">
    <div class="collection-container">
      <ul class="collection">
      {% comment %} Smart Collection Selection with Fallback {% endcomment %}
      {% if section.settings.best_sellers_collection != blank %}
          {% assign selected_collection = collections[section.settings.best_sellers_collection] %}
      {% elsif collections['best-sellers'] %}
          {% assign selected_collection = collections['best-sellers'] %}
      {% else %}
          {% assign selected_collection = collections.all %}
      {% endif %}
      
      {% if selected_collection and selected_collection.products.size > 0 %}
          {% for product in selected_collection.products %}
            <li class="decoration">
              <div class="product-card">
                <a href="{{ product.url }}" class="card-banner img-holder has-before" style="--width: 300; --height: 300;">
                  {% if product.featured_image %}
                    <img src="{{ product.featured_image | image_url: width: 600 }}" 
                      srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                              {{ product.featured_image | image_url: width: 450 }} 450w,
                              {{ product.featured_image | image_url: width: 600 }} 600w"
                      sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, 300px"
                      alt="{{ product.featured_image.alt | escape }}" 
                      class="img-cover" 
                      width="300" 
                      height="300" 
                      loading="lazy">
                  {% else %}
                   <img src="{{ 'default-image.jpg' | asset_url }}" 
                      alt="No image available" 
                      class="img-cover" 
                       width="300" 
                       height="300" 
                       loading="lazy">
                  {% endif %}
               <ul class="card-action-list">
                <li>
                 <button class="card-action-btn" aria-label="add to cart" title="add to cart">
                   {% render 'icon-velour', icon: 'add' %}
                 </button>
               </li>
               <li>
                 <form action="/cart/add" method="post" enctype="multipart/form-data" onsubmit="submitAddToCartForm(this); return false;">
                   <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                   <button type="submit" class="card-action-btn" aria-label="add to cart" title="add to cart">
                     {% render 'icon-velour', icon: 'bag-handle' %}
                   </button>
                 </form>
               </li>
       </ul>
       {% if product.compare_at_price > product.price %}
       <ul class="badge-list">
         <li>
           <div class="badge orange">Sale</div>
         </li>
         <li>
           <div class="badge cyan">
             10%
           </div>
         </li>
       </ul>
       {% endif %}
     </a>
          <div class="card-content">
             <h3 class="h3">
               <a href="{{ product.url }}" class="card-title">{{ product.title }}</a>
             </h3>
              <div class="card-price">
               {% if product.compare_at_price > product.price %}
                 <del class="del">{{ product.compare_at_price | money }}</del>
              {% endif %}
                 <data class="price" value="{{ product.price }}">{{ product.price | money }}</data>
               </div>
              </div>
             </div>
            </li>
          {% endfor %}
      {% else %}
          {% for i in (1..4) %}
            <li class="decoration">
              <div class="product-card">
                <a href="#" class="card-banner img-holder has-before" style="--width: 300; --height: 300;">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
                </a>
                <div class="card-content">
                  <h3 class="h3"><a href="#" class="card-title">Example Product {{ i }}</a></h3>
                  <div class="card-price"><data class="price" value="1999">$19.99</data></div>
                </div>
              </div>
            </li>
          {% endfor %}
      {% endif %}
      </ul>
    </div>
  </div>
</section>


<!-- Info Cards Section -->
<section class="section best-sellers__info">
  <div class="container">
    <div class="info-cards-wrapper">
      <div class="info-cards-grid">
    <!-- Why Shop With Us -->
    <div class="info-card features-card">
      <h3 class="info-card-title">
        {% render 'icon-velour', icon: 'star', class: 'title-icon' %}
        Why Our Best Sellers?
      </h3>
      <ul class="features-list">
        <li class="feature-item">
          {% render 'icon-velour', icon: 'checkmark-circle', class: 'feature-icon' %}
          <div class="feature-content">
            <h4>Verified Quality</h4>
            <p>Hand-picked products with verified customer reviews</p>
          </div>
        </li>
        <li class="feature-item">
          {% render 'icon-velour', icon: 'shield-checkmark', class: 'feature-icon' %}
          <div class="feature-content">
            <h4>100% Authentic</h4>
            <p>Guaranteed genuine products from trusted brands</p>
          </div>
        </li>
        <li class="feature-item">
          {% render 'icon-velour', icon: 'flash', class: 'feature-icon' %}
          <div class="feature-content">
            <h4>Fast Shipping</h4>
            <p>Express delivery on all best-selling items</p>
          </div>
        </li>
        <li class="feature-item">
          {% render 'icon-velour', icon: 'refresh', class: 'feature-icon' %}
          <div class="feature-content">
            <h4>Easy Returns</h4>
            <p>30-day hassle-free return policy</p>
          </div>
        </li>
      </ul>
    </div>

    <!-- Customer Reviews Summary -->
    <div class="info-card reviews-card">
      <h3 class="info-card-title">
        {% render 'icon-velour', icon: 'people', class: 'title-icon' %}
        Customer Love
      </h3>
      <div class="reviews-summary">
        <div class="rating-display">
          <div class="stars-large">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="rating-text">4.8 out of 5</p>
          <p class="review-count-text">Based on 2,847 reviews</p>
        </div>
        <div class="review-highlight">
          <p class="review-quote">"Amazing quality and fast delivery! These best sellers never disappoint."</p>
          <p class="review-author">- Sarah M.</p>
        </div>
      </div>
    </div>

    <!-- Special Offer Banner -->
    <div class="info-card offer-card">
      <div class="offer-badge">Limited Time</div>
      <h3 class="offer-title">Get 15% Off</h3>
      <p class="offer-description">On your first purchase of any best seller</p>
      <div class="offer-code">
        <span class="code-label">Use code:</span>
        <span class="code-value">BEST15</span>
      </div>
      <a href="#" class="btn btn-primary">Shop Now</a>
    </div>

      </div>
    </div>
  </div>
</section>
</div>

<style>
  .best-sellers {
    color: var(--color-text);
  }

  /* Hero slider */
  .best-sellers .hero1 {
    position: relative;
    min-height: clamp(360px, 70vh, 640px);
    padding-block: clamp(70px, 10vw, 140px);
    overflow: hidden;
  }

  .best-sellers .hero1-slider {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .best-sellers .hero1 .slider-item {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    opacity: 0;
    visibility: hidden;
    transition: var(--transition-2);
  }

  .best-sellers .hero1 .slider-item.active {
    opacity: 1;
    visibility: visible;
  }

  .best-sellers .hero1 .slider-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    transform: scale(1.05);
  }

  .best-sellers .hero1 .slider-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  .best-sellers .hero1 .slider-item.active .slider-bg {
    animation: smoothScale 7s linear forwards;
  }

  @keyframes smoothScale {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.12);
    }
  }

  .best-sellers .hero1 .container {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .best-sellers .hero1 .card-content {
    max-width: 520px;
    display: grid;
    gap: 14px;
  }

  .best-sellers .hero1 .hero1-title {
    font-size: clamp(3.2rem, 6vw, 6.6rem);
    line-height: 1.05;
    font-weight: var(--fw-500);
    color: #fff !important;
  }

  .best-sellers .hero1 .price {
    color: #fff !important;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: var(--fs-6);
  }

  .best-sellers .hero1-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .best-sellers .slider-reveal {
    transform: translateY(24px);
    opacity: 0;
  }

  .best-sellers .hero1 .slider-item.active .slider-reveal {
    animation: sliderReveal 0.9s ease forwards;
  }

  @keyframes sliderReveal {
    0% {
      transform: translateY(24px);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .best-sellers .hero1 .slider-item.active .hero1-title {
    animation-delay: 200ms;
  }

  .best-sellers .hero1 .slider-item.active .price {
    animation-delay: 400ms;
  }

  .best-sellers .hero1 .slider-item.active .btn {
    animation-delay: 600ms;
  }

  .best-sellers .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.35);
    color: #fff;
    border: 1px solid #fff;
    cursor: pointer;
    z-index: 2;
    transition: var(--transition-1);
  }

  .best-sellers .slider-btn:hover {
    background: #fff;
    color: #000;
  }

  .best-sellers .slider-btn.prev {
    left: 20px;
  }

  .best-sellers .slider-btn.next {
    right: 20px;
  }

  /* Products grid */
  .best-sellers__products .collection-container {
    margin-top: 10px;
  }

  .best-sellers__products .collection {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .best-sellers__products .product-card {
    height: 100%;
  }

  .best-sellers__products .card-action-btn {
    background: var(--color-background);
    border: 1px solid currentColor;
    box-shadow: none;
  }

  .best-sellers__products .card-action-btn:hover {
    background: currentColor;
    color: var(--color-background);
  }

  .best-sellers__products .badge {
    font-size: 1.1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* Info cards */
  .best-sellers__info .info-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
    width: 100%;
  }

  .best-sellers__info .info-card {
    padding: 28px;
    border: 1px solid currentColor;
    background: var(--color-background);
    transition: transform var(--transition-1);
  }

  .best-sellers__info .info-card:hover {
    transform: translateY(-2px);
  }

  .best-sellers__info .info-card-title {
    font-size: var(--fs-3);
    font-weight: var(--fw-500);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .best-sellers__info .title-icon {
    color: var(--color-button);
  }

  .best-sellers__info .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }

  .best-sellers__info .feature-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px;
    align-items: start;
  }

  .best-sellers__info .feature-icon {
    color: var(--color-button);
  }

  .best-sellers__info .feature-content h4 {
    font-size: var(--fs-4);
    font-weight: var(--fw-500);
    margin: 0 0 4px;
  }

  .best-sellers__info .feature-content p {
    margin: 0;
    opacity: 0.8;
  }

  .best-sellers__info .rating-display {
    border: 1px solid currentColor;
    padding: 16px;
    margin-bottom: 14px;
  }

  .best-sellers__info .stars-large {
    font-size: 1.6rem;
    letter-spacing: 3px;
    color: var(--color-button);
  }

  .best-sellers__info .rating-text {
    font-size: var(--fs-4);
    font-weight: var(--fw-500);
    margin: 6px 0 2px;
  }

  .best-sellers__info .review-count-text {
    font-size: 1.3rem;
    opacity: 0.75;
  }

  .best-sellers__info .review-highlight {
    border-left: 2px solid currentColor;
    padding-left: 12px;
  }

  .best-sellers__info .review-quote {
    font-style: italic;
    margin: 0 0 6px;
  }

  .best-sellers__info .review-author {
    margin: 0;
    font-weight: var(--fw-500);
  }

  .best-sellers__info .offer-card {
    text-align: center;
  }

  .best-sellers__info .offer-badge {
    display: inline-block;
    background: var(--color-button);
    color: var(--color-button-label);
    padding: 4px 10px;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 10px;
  }

  .best-sellers__info .offer-title {
    font-size: var(--fs-3);
    margin: 0 0 8px;
  }

  .best-sellers__info .offer-description {
    margin: 0 0 14px;
    opacity: 0.85;
  }

  .best-sellers__info .offer-code {
    border: 1px solid currentColor;
    padding: 12px;
    margin-bottom: 16px;
  }

  .best-sellers__info .code-label {
    font-size: 1.1rem;
    opacity: 0.7;
    display: block;
    margin-bottom: 4px;
  }

  .best-sellers__info .code-value {
    font-size: 1.6rem;
    letter-spacing: 2px;
    font-family: "Courier New", monospace;
    font-weight: 700;
    color: var(--color-button) !important;
  }

  @media (max-width: 749px) {
    .best-sellers .slider-btn {
      display: none;
    }

    .best-sellers .hero1 {
      padding-block: calc(var(--section-padding) * 2);
    }
  }
</style>

<script>
(function() {
  'use strict';

  document.querySelectorAll('[data-best-sellers]').forEach((root) => {
    const heroSliderItems = root.querySelectorAll('[data-hero-slider-item]');
    if (!heroSliderItems.length) {
      return;
    }

    const heroSliderPrevBtn = root.querySelector('[data-prev-btn]');
    const heroSliderNextBtn = root.querySelector('[data-next-btn]');

    let currentSlidePos = 0;
    let lastActiveSliderItem = heroSliderItems[0];

    const updateSliderPos = function() {
      lastActiveSliderItem.classList.remove('active');
      heroSliderItems[currentSlidePos].classList.add('active');
      lastActiveSliderItem = heroSliderItems[currentSlidePos];
    };

    const slideNext = function() {
      currentSlidePos = (currentSlidePos >= heroSliderItems.length - 1) ? 0 : currentSlidePos + 1;
      updateSliderPos();
    };

    const slidePrev = function() {
      currentSlidePos = (currentSlidePos < 1) ? heroSliderItems.length - 1 : currentSlidePos - 1;
      updateSliderPos();
    };

    if (heroSliderPrevBtn) {
      heroSliderPrevBtn.addEventListener('click', slidePrev);
    }

    if (heroSliderNextBtn) {
      heroSliderNextBtn.addEventListener('click', slideNext);
    }

    let autoSlideInterval;
    const autoSlide = function() {
      autoSlideInterval = setInterval(slideNext, 5000);
    };

    const stopAutoSlide = function() {
      clearInterval(autoSlideInterval);
    };

    root.addEventListener('mouseenter', stopAutoSlide);
    root.addEventListener('mouseleave', autoSlide);

    [heroSliderNextBtn, heroSliderPrevBtn].forEach((btn) => {
      if (!btn) {
        return;
      }
      btn.addEventListener('mouseenter', stopAutoSlide);
      btn.addEventListener('mouseleave', autoSlide);
    });

    window.addEventListener('load', autoSlide, { once: true });
  });
})();
</script>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    {
      "type": "color_scheme","id": "color_scheme","label": "Color scheme","default": "scheme-1"
    },
    {
      "type": "collection",
      "id": "best_sellers_collection",
      "label": "Best Sellers Collection",
      "info": "Select a collection to display. If not selected, it will default to 'best-sellers' collection, or all products if that doesn't exist."
    }
  ],
  "blocks": [
    {
      "type": "hero_section",
      "name": "Hero Section",
      "settings": [
        {
          "type": "image_picker",
          "id": "hero_image",
          "label": "Hero Image"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "default": "Brand Name"
        },
        {
          "type": "text",
          "id": "starting_price",
          "label": "Starting Price",
          "default": "$17.99"
        },
        {
          "type": "url",
          "id": "shop_now_link",
          "label": "Shop Now Button Link"
        },
        {
          "type": "text",
          "id": "shop_now_text",
          "label": "Shop Now Button Text",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Best Sellers",
      "blocks": [
        {
          "type": "hero_section",
          "settings": {
            "brand_name": "Luxury Essence",
            "starting_price": "$29.99"
          }
        },
        {
          "type": "hero_section",
          "settings": {
            "brand_name": "Velour Midnight",
            "starting_price": "$34.99"
          }
        }
      ]
    }
  ]
}
{% endschema %}

