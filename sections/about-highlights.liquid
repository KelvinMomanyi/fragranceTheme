<section class="section about-highlights color-scheme-{{ section.settings.color_scheme }}" style="{% render 'color-scheme-styles', scheme: section.settings.color_scheme %}">
  <div class="container">
    <div class="about-highlights__header">
      <h2 class="about-highlights__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="about-highlights__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="about-highlights__grid about-highlights__grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        <div class="about-highlights__card" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <img
              src="{{ block.settings.icon | image_url: width: 160 }}"
              alt="{{ block.settings.icon.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.icon.width }}"
              height="{{ block.settings.icon.height }}"
            >
          {%- endif -%}
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
          {%- if block.settings.link_label != blank and block.settings.link != blank -%}
            <a class="about-highlights__link" href="{{ block.settings.link }}">{{ block.settings.link_label }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .about-highlights__header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 32px;
  }

  .about-highlights__title {
    font-size: clamp(2rem, 3.4vw, 3rem);
    margin: 0 0 12px;
    color: var(--color-text);
  }

  .about-highlights__subtitle {
    color: var(--color-text);
    opacity: 0.8;
    font-size: 1.5rem;
  }

  .about-highlights__grid {
    display: grid;
    gap: 20px;
  }

  .about-highlights__grid--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .about-highlights__grid--3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .about-highlights__grid--4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .about-highlights__card {
    border: 1px solid var(--color-text);
    padding: 24px;
    display: grid;
    gap: 12px;
    background: transparent;
  }

  .about-highlights__card img {
    width: 48px;
    height: 48px;
    object-fit: cover;
  }

  .about-highlights__card h3 {
    margin: 0;
    font-size: 1.6rem;
    color: var(--color-text);
  }

  .about-highlights__card p {
    margin: 0;
    color: var(--color-text);
    opacity: 0.85;
  }

  .about-highlights__link {
    color: var(--color-button);
    text-transform: uppercase;
    font-size: 1.2rem;
    letter-spacing: 0.12em;
  }

  @media (max-width: 990px) {
    .about-highlights__grid--4 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 749px) {
    .about-highlights__grid--2,
    .about-highlights__grid--3,
    .about-highlights__grid--4 {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "About highlights",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What makes us different"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Thoughtful sourcing, intentional blends, and a ritual-first mindset."
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Desktop columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Curated profiles"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Every blend is reviewed for balance and longevity."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About highlights",
      "blocks": [
        { "type": "highlight" },
        { "type": "highlight" },
        { "type": "highlight" }
      ]
    }
  ]
}
{% endschema %}
